  const statusBadge = s => ({ paid:'badge-success', unpaid:'badge-warning', partial:'badge-info', cancelled:'badge-danger' }[s] || 'badge-secondary');

  document.getElementById('purchases-list-body').innerHTML = filtered.reverse().map(doc => `
