      <td>${doc.date||'-'}</td>
      <td>${doc.dueDate||'-'}</td>
      <td style="font-weight:700;direction:ltr">$${fmt(doc.total)}</td>
      <td><span class="badge ${statusBadge(doc.status)}">${statusLabel(doc.status)}</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-outline" onclick="editDoc('purchases',${doc.id})">✏️ تعديل</button>
        <button class="btn btn-sm btn-outline" onclick="printDoc('purchases',${doc.id})" style="margin-right:4px">🖨</button>
        <button class="btn btn-sm btn-danger" onclick="deleteDoc('purchases',${doc.id})" style="margin-right:4px">🗑</button>
      </td>
    </tr>
  `).join('') || '<tr><td colspan="7"><div class="empty-state"><div class="icon">🛒</div><p>لا توجد مشتريات</p></div></td></tr>';
}

async function editDoc(type, id) {
  // Navigate to that doc type page and load the doc
  showPageOnly(type);
  await openDocPage(type, id);
}

async function printDoc(type, id) {
  await editDoc(type, id);
  setTimeout(()=>window.print(), 600);
}

async function deleteDoc(type, id) {
  if (!confirm('هل تريد حذف هذا المستند؟')) return;
  await dbDelete(DOC_TYPES[type].store, id);
  notify('تم الحذف');
  if (type==='invoices') renderInvoicesList();
  else if (type==='purchases') renderPurchasesList();
}

function showPageOnly(page) {
  document.querySelectorAll('.page-view').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');
}

// ============ DASHBOARD ============
async function renderDashboard() {
  if (!currentCompany) return;

  const isBarber = currentCompany.business_type === 'barber';

  if (isBarber) {
    await renderBarberDashboard();
  } else {
    await renderTradingDashboard();
  }
}

async function renderTradingDashboard() {
  const [itemsRes, invoicesRes] = await Promise.all([
    supabaseClient.from('items').select('*').eq('company_id', currentCompany.id),
    supabaseClient.from('invoices').select('*').eq('company_id', currentCompany.id),
  ]);
  const items = itemsRes.data || [];
  const invoices = invoicesRes.data || [];

  const totalRevenue = invoices.reduce((s,i) => s+parseFloat(i.total||0), 0);
  const paidCount = invoices.filter(i=>i.status==='paid').length;
  const lowStock = items.filter(i => i.stock <= i.minStock);

  document.getElementById('dashboard-stats').innerHTML = `
    <div class="stat-card"><div class="stat-label">إجمالي الإيرادات</div><div class="stat-value">$${fmt(totalRevenue)}</div><div class="stat-sub">↑ 12% من الشهر الماضي</div></div>
    <div class="stat-card"><div class="stat-label">الفواتير المدفوعة</div><div class="stat-value">${paidCount}</div><div class="stat-sub">من أصل ${fmtInt(invoices.length)} فاتورة</div></div>
    <div class="stat-card"><div class="stat-label">أصناف المخزون</div><div class="stat-value">${fmtInt(items.length)}</div><div class="stat-sub">${fmtInt(items.reduce((s,i)=>s+i.stock,0))} وحدة إجمالية</div></div>
    <div class="stat-card"><div class="stat-label">أصناف منخفضة</div><div class="stat-value" style="color:var(--danger)">${fmtInt(lowStock.length)}</div><div class="stat-sub">تحتاج لإعادة طلب</div></div>
  `;

  const vals = [65,80,72,90,85,95];
  const mx = Math.max(...vals);
  document.getElementById('sales-chart').innerHTML = vals.map(v=>`<div class="mini-bar" style="height:${(v/mx*100)}%"></div>`).join('');
  const months = ['نوفمبر','ديسمبر','يناير','فبراير','مارس','أبريل'];
  document.getElementById('chart-months').innerHTML = months.map(m=>`<span>${m}</span>`).join('');

  document.getElementById('low-stock-list').innerHTML = lowStock.length ?
    lowStock.slice(0,5).map(i=>`<div class="flex-between" style="padding:8px 0;border-bottom:1px solid var(--border-light);font-size:13px"><span>${i.name}</span><span class="badge badge-danger">مخزون: ${fmtInt(i.stock)}</span></div>`).join('') :
    '<div class="empty-state" style="padding:20px"><p style="font-size:13px">✅ المخزون في وضع جيد</p></div>';

  document.getElementById('recent-invoices-list').innerHTML = invoices.slice(-5).reverse().map(inv=>`
    <div class="flex-between" style="padding:8px 0;border-bottom:1px solid var(--border-light);font-size:13px">
      <div><div style="font-weight:600">${inv.number}</div><div style="color:var(--text-muted)">${inv.party}</div></div>
      <div style="text-align:left"><div style="font-weight:700;direction:ltr">$${fmt(inv.total)}</div><span class="badge ${inv.status==='paid'?'badge-success':'badge-warning'}">${inv.status==='paid'?'مدفوعة':'غير مدفوعة'}</span></div>
    </div>`).join('');

  const custMap = {};
  invoices.forEach(i => { custMap[i.party] = (custMap[i.party]||0)+parseFloat(i.total||0); });
  const top = Object.entries(custMap).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const mx2 = top[0]?.[1]||1;
  document.getElementById('top-customers-list').innerHTML = top.map(([name,val])=>`
    <div style="margin-bottom:12px">
      <div class="flex-between" style="font-size:13px;margin-bottom:4px"><span style="font-weight:600">${name}</span><span style="direction:ltr">$${fmt(val)}</span></div>
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${(val/mx2*100).toFixed(0)}%"></div></div>
    </div>`).join('');
}

async function renderBarberDashboard() {
  const today = new Date().toISOString().split('T')[0];
  const thisMonth = new Date().toISOString().slice(0, 7);

  const [resRes, empRes, supRes, billRes] = await Promise.all([
    supabaseClient.from('reservations').select('*').eq('company_id', currentCompany.id),
    supabaseClient.from('employees').select('*').eq('company_id', currentCompany.id).eq('active', true),
    supabaseClient.from('supplies').select('*').eq('company_id', currentCompany.id),
    supabaseClient.from('bills').select('*').eq('company_id', currentCompany.id),
  ]);

  const allRes = resRes.data || [];
  const employees = empRes.data || [];
  const supplies = supRes.data || [];
  const bills = billRes.data || [];

  const todayRes = allRes.filter(r => r.date === today);
  const monthDone = allRes.filter(r => r.date?.startsWith(thisMonth) && r.status === 'done');
  const monthRevenue = monthDone.reduce((s, r) => s + parseFloat(r.price || 0), 0);
  const monthSupplies = supplies.filter(s => s.date?.startsWith(thisMonth)).reduce((s, r) => s + parseFloat(r.amount || 0), 0);
  const monthBills = bills.filter(b => b.month === thisMonth).reduce((s, b) => s + parseFloat(b.amount || 0), 0);
  const totalExpenses = monthSupplies + monthBills;
  const netProfit = monthRevenue - totalExpenses;
  const todayCuts = todayRes.filter(r => r.status === 'done').length;

  // ===== STATS =====
  document.getElementById('dashboard-stats').innerHTML = `
    <div class="stat-card">
      <div class="stat-label">إيرادات هذا الشهر</div>
      <div class="stat-value" style="font-size:20px;direction:ltr">$${fmt(monthRevenue)}</div>
      <div class="stat-sub">${fmtInt(monthDone.length)} خدمة منجزة</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">مصاريف هذا الشهر</div>
      <div class="stat-value" style="font-size:20px;color:var(--danger);direction:ltr">$${fmt(totalExpenses)}</div>
      <div class="stat-sub">مستلزمات + فواتير ثابتة</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">صافي الربح</div>
      <div class="stat-value" style="font-size:20px;color:${netProfit>=0?'var(--success)':'var(--danger)'};direction:ltr">$${fmt(netProfit)}</div>
      <div class="stat-sub">${netProfit >= 0 ? '✅ ربح' : '⚠️ خسارة'}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">قطعات اليوم</div>
      <div class="stat-value">${fmtInt(todayCuts)}</div>
      <div class="stat-sub">من أصل ${fmtInt(todayRes.length)} حجز</div>
    </div>
  `;

  // ===== TODAY'S APPOINTMENTS =====
  const statusLabel = { pending:'قيد الانتظار', confirmed:'مؤكد', done:'منجز', cancelled:'ملغى' };
  const statusBadge = { pending:'badge-warning', confirmed:'badge-info', done:'badge-success', cancelled:'badge-danger' };

  const todayHtml = todayRes.length ? todayRes
    .sort((a,b) => (a.time||'').localeCompare(b.time||''))
    .map(r => `
      <div class="flex-between" style="padding:10px 0;border-bottom:1px solid var(--border-light);font-size:13px">
        <div style="display:flex;align-items:center;gap:12px">
          <div style="font-size:18px">💈</div>
          <div>
            <div style="font-weight:700">${r.customer_name}</div>
            <div style="color:var(--text-muted);font-size:12px">${r.service_name||'-'} • ${r.employee_name||'-'}</div>
          </div>
        </div>
        <div style="text-align:left">
          <div style="font-weight:700;direction:ltr">${r.time||'-'}</div>
          <span class="badge ${statusBadge[r.status]||'badge-secondary'}">${statusLabel[r.status]||r.status}</span>
        </div>
      </div>
    `).join('') :
    '<div class="empty-state" style="padding:24px"><p style="font-size:13px">لا توجد حجوزات اليوم</p></div>';

  // ===== BARBER PERFORMANCE =====
  const maxCuts = Math.max(...employees.map(emp => {
    return monthDone.filter(r => r.employee_id === emp.id).length;
  }), 1);

  const barberHtml = employees.length ? employees.map(emp => {
    const empRes = monthDone.filter(r => r.employee_id === emp.id);
    const empRevenue = empRes.reduce((s, r) => s + parseFloat(r.price || 0), 0);
    let due = 0;
    if (emp.salary_type === 'commission') due = empRevenue * (emp.commission_rate / 100);
    else if (emp.salary_type === 'salary_commission') due = parseFloat(emp.base_salary || 0) + empRevenue * (emp.commission_rate / 100);
    else due = parseFloat(emp.base_salary || 0);
    const pct = ((empRes.length / maxCuts) * 100).toFixed(0);
    return `
      <div style="margin-bottom:14px">
        <div class="flex-between" style="font-size:13px;margin-bottom:6px">
          <div>
            <span style="font-weight:700">${emp.name}</span>
            <span style="color:var(--text-muted);font-size:11px;margin-right:8px">${emp.level}</span>
          </div>
          <div style="text-align:left">
            <span style="font-weight:700;direction:ltr">$${fmt(empRevenue)}</span>
            <span style="color:var(--text-muted);font-size:11px"> • ${fmtInt(empRes.length)} قطعة</span>
          </div>
        </div>
        <div class="progress-bar-wrap">
          <div class="progress-bar-fill" style="width:${pct}%"></div>
        </div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:4px">
          عمولة مستحقة: <span style="color:var(--success);font-weight:700;direction:ltr">$${fmt(due)}</span>
        </div>
      </div>
    `;
  }).join('') : '<div style="padding:16px;text-align:center;color:var(--text-muted)">لا يوجد موظفون</div>';

  // ===== POPULAR SERVICES =====
  const serviceCount = {};
  const serviceRevenue = {};
  monthDone.forEach(r => {
    if (r.service_name) {
      serviceCount[r.service_name] = (serviceCount[r.service_name] || 0) + 1;
      serviceRevenue[r.service_name] = (serviceRevenue[r.service_name] || 0) + parseFloat(r.price || 0);
    }
  });
  const topServices = Object.entries(serviceCount).sort((a,b) => b[1]-a[1]).slice(0,5);
  const maxSvc = topServices[0]?.[1] || 1;

  const servicesHtml = topServices.length ? topServices.map(([name, count]) => `
    <div style="margin-bottom:12px">
      <div class="flex-between" style="font-size:13px;margin-bottom:4px">
        <span style="font-weight:600">${name}</span>
        <span style="direction:ltr;color:var(--text-muted)">${fmtInt(count)} مرة • $${fmt(serviceRevenue[name])}</span>
      </div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill" style="width:${((count/maxSvc)*100).toFixed(0)}%;background:var(--accent)"></div>
      </div>
    </div>
  `).join('') : '<div style="padding:16px;text-align:center;color:var(--text-muted)">لا توجد بيانات بعد</div>';

  // ===== RENDER INTO PAGE =====
  const dashboardPage = document.getElementById('page-dashboard');
  dashboardPage.innerHTML = `
    <div class="flex-between mb-4 no-print">
      <div>
        <h1 style="font-size:22px;font-weight:900;color:var(--primary)">لوحة التحكم</h1>
        <p class="text-muted">${new Date().toLocaleDateString('ar-LB', {weekday:'long', year:'numeric', month:'long', day:'numeric'})}</p>
      </div>
      <div class="flex gap-2">
        <button class="btn btn-primary" onclick="openReservationModal()">📅 حجز جديد</button>
        <button class="btn btn-outline" onclick="showPage('supplies')">🧴 مستلزم</button>
      </div>
    </div>

    <div class="stats-grid" id="dashboard-stats"></div>

    <div class="grid-2">
      <div class="card">
        <div class="card-header">
          <div class="card-title">📅 حجوزات اليوم</div>
          <button class="btn btn-sm btn-outline" onclick="showPage('reservations')">عرض الكل</button>
        </div>
        ${todayHtml}
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">👥 أداء الحلاقين هذا الشهر</div>
        </div>
        ${barberHtml}
      </div>
    </div>

    <div class="grid-2 mt-4">
      <div class="card">
        <div class="card-header">
          <div class="card-title">✂️ الخدمات الأكثر طلباً</div>
        </div>
        ${servicesHtml}
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">💰 ملخص مالي</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;padding:8px 0">
          <div class="flex-between" style="font-size:14px;padding:10px;background:var(--bg-panel);border-radius:8px">
            <span>إيرادات الشهر</span>
            <span style="font-weight:700;color:var(--success);direction:ltr">+$${fmt(monthRevenue)}</span>
          </div>
          <div class="flex-between" style="font-size:14px;padding:10px;background:var(--bg-panel);border-radius:8px">
            <span>مستلزمات</span>
            <span style="font-weight:700;color:var(--danger);direction:ltr">-$${fmt(monthSupplies)}</span>
          </div>
          <div class="flex-between" style="font-size:14px;padding:10px;background:var(--bg-panel);border-radius:8px">
            <span>فواتير ثابتة</span>
            <span style="font-weight:700;color:var(--danger);direction:ltr">-$${fmt(monthBills)}</span>
          </div>
          <div class="flex-between" style="font-size:15px;font-weight:700;padding:12px;background:${netProfit>=0?'#D4EDDA':'#F8D7DA'};border-radius:8px;border:1px solid ${netProfit>=0?'#C3E6CB':'#F5C6CB'}">
            <span style="color:${netProfit>=0?'#155724':'#721C24'}">صافي الربح</span>
            <span style="direction:ltr;color:${netProfit>=0?'#155724':'#721C24'}">$${fmt(netProfit)}</span>
          </div>
        </div>
      </div>
    </div>
  `;

  // Re-render stats into the stats grid
  document.getElementById('dashboard-stats').innerHTML = `
    <div class="stat-card">
      <div class="stat-label">إيرادات هذا الشهر</div>
      <div class="stat-value" style="font-size:20px;direction:ltr">$${fmt(monthRevenue)}</div>
      <div class="stat-sub">${fmtInt(monthDone.length)} خدمة منجزة</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">مصاريف هذا الشهر</div>
      <div class="stat-value" style="font-size:20px;color:var(--danger);direction:ltr">$${fmt(totalExpenses)}</div>
      <div class="stat-sub">مستلزمات + فواتير ثابتة</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">صافي الربح</div>
      <div class="stat-value" style="font-size:20px;color:${netProfit>=0?'var(--success)':'var(--danger)'};direction:ltr">$${fmt(netProfit)}</div>
      <div class="stat-sub">${netProfit >= 0 ? '✅ ربح' : '⚠️ خسارة'}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">قطعات اليوم</div>
      <div class="stat-value">${fmtInt(todayCuts)}</div>
      <div class="stat-sub">من أصل ${fmtInt(todayRes.length)} حجز</div>
    </div>
  `;
}

// ============ ITEMS ============
async function renderItems() {
  const items = await dbGetAll('items');
  const search = (document.getElementById('item-search')?.value||'').toLowerCase();
  const catFilter = document.getElementById('item-cat-filter')?.value||'';
  const cats = [...new Set(items.map(i=>i.category).filter(Boolean))];
  const catEl = document.getElementById('item-cat-filter');
  if (catEl) {
    const cur = catEl.value;
    catEl.innerHTML = '<option value="">كل الفئات</option>'+cats.map(c=>`<option value="${c}" ${c===cur?'selected':''}>${c}</option>`).join('');
  }
  const filtered = items.filter(i => {
    const ms = !search||(i.name||'').toLowerCase().includes(search)||(i.code||'').toLowerCase().includes(search);
    return ms && (!catFilter||i.category===catFilter);
  });
  const tbody = document.getElementById('items-table-body');
  tbody.innerHTML = filtered.map(item => {
    const low = item.stock <= item.minStock;
    return `<tr>
      <td><code>${item.code||''}</code></td>
      <td><div style="font-weight:600">${item.name}</div><div style="font-size:11px;color:var(--text-muted)">${item.desc||''}</div></td>
      <td>${item.category||''}</td>
      <td style="direction:ltr">$${fmt(item.cost)}</td>
      <td style="color:var(--success);font-weight:700;direction:ltr">$${fmt(item.price)}</td>
      <td style="font-weight:700;color:${low?'var(--danger)':'inherit'}">${fmtInt(item.stock)} ${item.unit||''}</td>
      <td>${fmtInt(item.minStock)}</td>
      <td><span class="badge ${low?'badge-danger':'badge-success'}">${low?'منخفض':'متوفر'}</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-outline" onclick="editItem(${item.id})">✏️</button>
        <button class="btn btn-sm btn-danger" style="margin-right:4px" onclick="deleteItem(${item.id})">🗑</button>
      </td>
    </tr>`;
  }).join('') || '<tr><td colspan="9"><div class="empty-state"><div class="icon">📦</div><p>لا توجد أصناف</p></div></td></tr>';
}

function openItemModal() {
  document.getElementById('edit-item-id').value='';
  document.getElementById('item-code').value='';
  document.getElementById('item-name').value='';
  document.getElementById('item-category').value='';
  document.getElementById('item-desc').value='';
  document.getElementById('item-cost').value=0;
  document.getElementById('item-price').value=0;
  document.getElementById('item-stock').value=0;
  document.getElementById('item-min-stock').value=5;
  document.getElementById('item-modal-title').textContent='➕ إضافة صنف جديد';
  openModal('item-modal');
}

async function editItem(id) {
  const item = await dbGet('items', id);
  if (!item) return;
  document.getElementById('edit-item-id').value=item.id;
  document.getElementById('item-code').value=item.code||'';
  document.getElementById('item-name').value=item.name||'';
  document.getElementById('item-category').value=item.category||'';
  document.getElementById('item-unit').value=item.unit||'قطعة';
  document.getElementById('item-cost').value=item.cost||0;
  document.getElementById('item-price').value=item.price||0;
  document.getElementById('item-stock').value=item.stock||0;
  document.getElementById('item-min-stock').value=item.minStock||0;
  document.getElementById('item-desc').value=item.desc||'';
  document.getElementById('item-modal-title').textContent='✏️ تعديل الصنف';
  openModal('item-modal');
}

async function saveItem() {
  const name = document.getElementById('item-name').value.trim();
  if (!name) { notify('أدخل اسم الصنف','error'); return; }
  const editId = document.getElementById('edit-item-id').value;
  const data = {
    code:document.getElementById('item-code').value,
    name,
    category:document.getElementById('item-category').value,
    unit:document.getElementById('item-unit').value,
    cost:parseFloat(document.getElementById('item-cost').value)||0,
    price:parseFloat(document.getElementById('item-price').value)||0,
    stock:parseInt(document.getElementById('item-stock').value)||0,
    minStock:parseInt(document.getElementById('item-min-stock').value)||0,
    desc:document.getElementById('item-desc').value,
  };
  if (editId) data.id=parseInt(editId);
  await dbPut('items', data);
  closeModal('item-modal');
  notify('تم حفظ الصنف بنجاح');
  renderItems();
}

async function deleteItem(id) {
  if (!confirm('هل تريد حذف هذا الصنف؟')) return;
  await dbDelete('items', id);
  notify('تم حذف الصنف');
  renderItems();
}

function exportItemsCSV() {
  dbGetAll('items').then(items => {
    const rows = [['Code','Name','Category','Cost','Price','Stock'],...items.map(i=>[i.code,i.name,i.category,i.cost,i.price,i.stock])];
    const a = document.createElement('a');
    a.href='data:text/csv;charset=utf-8,'+encodeURIComponent('\ufeff'+rows.map(r=>r.join(',')).join('\n'));
    a.download='items.csv'; a.click();
  });
}

// ============ STOCK REPORT ============
async function renderStockReport() {
  const items = await dbGetAll('items');
  const tv = items.reduce((s,i)=>s+(i.stock*i.cost),0);
  const lc = items.filter(i=>i.stock<=i.minStock).length;
  document.getElementById('stock-stats').innerHTML = `
    <div class="stat-card"><div class="stat-label">إجمالي الأصناف</div><div class="stat-value">${fmtInt(items.length)}</div></div>
    <div class="stat-card"><div class="stat-label">إجمالي الوحدات</div><div class="stat-value">${fmtInt(items.reduce((s,i)=>s+i.stock,0))}</div></div>
    <div class="stat-card"><div class="stat-label">قيمة المخزون</div><div class="stat-value" style="font-size:18px;direction:ltr">$${fmt(tv)}</div></div>
    <div class="stat-card"><div class="stat-label">أصناف منخفضة</div><div class="stat-value" style="color:var(--danger)">${fmtInt(lc)}</div></div>
  `;
  document.getElementById('stock-report-body').innerHTML = items.map(i=>{
    const low=i.stock<=i.minStock;
    return `<tr>
      <td><code>${i.code}</code></td>
      <td style="font-weight:600">${i.name}</td>
      <td>${fmtInt(i.stock)}</td>
      <td style="color:var(--success)">0</td>
      <td style="color:var(--danger)">0</td>
      <td style="font-weight:700;color:${low?'var(--danger)':'var(--primary)'}">${fmtInt(i.stock)} ${i.unit}</td>
      <td style="direction:ltr">$${fmt(i.stock*i.cost)}</td>
      <td><span class="badge ${low?'badge-danger':'badge-success'}">${low?'منخفض':'متوفر'}</span></td>
    </tr>`;
  }).join('');
}

function exportStockReport() {
  dbGetAll('items').then(items=>{
    const rows=[['Code','Item','Stock','Value'],...items.map(i=>[i.code,i.name,i.stock,(i.stock*i.cost).toFixed(2)])];
    const a=document.createElement('a');
    a.href='data:text/csv;charset=utf-8,'+encodeURIComponent('\ufeff'+rows.map(r=>r.join(',')).join('\n'));
    a.download='stock.csv';a.click();
  });
}

// ============ WAREHOUSES ============
async function renderWarehouses() {
  const ws = await dbGetAll('warehouses');
  document.getElementById('warehouses-grid').innerHTML = ws.map(w=>`
    <div class="card" style="text-align:center">
      <div style="font-size:32px;margin-bottom:12px">🏭</div>
      <div style="font-size:16px;font-weight:700;color:var(--primary)">${w.name}</div>
      <div style="color:var(--text-muted);font-size:13px;margin-top:6px">📍 ${w.location}</div>
      <div style="color:var(--text-muted);font-size:13px;margin-top:4px">👤 ${w.manager}</div>
      <div style="margin-top:16px;display:flex;gap:8px;justify-content:center">
        <button class="btn btn-sm btn-danger" onclick="dbDelete('warehouses',${w.id}).then(renderWarehouses)">🗑 حذف</button>
      </div>
    </div>`).join('') || '<div class="empty-state"><div class="icon">🏭</div><p>لا توجد مخازن</p></div>';
}

async function saveWarehouse() {
  const name = document.getElementById('wh-name').value;
  if (!name) { notify('أدخل اسم المخزن','error'); return; }
  await dbPut('warehouses',{name,location:document.getElementById('wh-location').value,manager:document.getElementById('wh-manager').value});
  closeModal('warehouse-modal'); notify('تم إضافة المخزن'); renderWarehouses();
}

// ============ ACCOUNTS ============
async function renderAccounts() {
  const accounts = await dbGetAll('accounts');
  const search = (document.getElementById('account-search')?.value||'').toLowerCase();
  const tf = document.getElementById('account-type-filter')?.value||'';
  const filtered = accounts.filter(a=>(!search||(a.name||'').toLowerCase().includes(search)||(a.code||'').includes(search))&&(!tf||a.type===tf));
  const tl={asset:'أصول',liability:'خصوم',equity:'حقوق ملكية',revenue:'إيرادات',expense:'مصاريف'};
  const tb={asset:'badge-info',liability:'badge-danger',equity:'badge-secondary',revenue:'badge-success',expense:'badge-warning'};
  document.getElementById('accounts-table-body').innerHTML = filtered.map(a=>{
    const bal=(a.debit||0)-(a.credit||0);
    return `<tr>
      <td><code>${a.code}</code></td>
      <td style="font-weight:600">${a.name}</td>
      <td><span class="badge ${tb[a.type]||'badge-secondary'}">${tl[a.type]||a.type}</span></td>
      <td style="direction:ltr">${fmt(a.debit||0)}</td>
      <td style="direction:ltr">${fmt(a.credit||0)}</td>
      <td style="font-weight:700;color:${bal>=0?'var(--success)':'var(--danger)'};direction:ltr">${fmt(Math.abs(bal))} ${bal>=0?'Dr':'Cr'}</td>
      <td class="no-print"><button class="btn btn-sm btn-danger" onclick="dbDelete('accounts',${a.id}).then(renderAccounts)">🗑</button></td>
    </tr>`;
  }).join('')||'<tr><td colspan="7"><div class="empty-state"><div class="icon">📒</div><p>لا توجد حسابات</p></div></td></tr>';
}

async function saveAccount() {
  const code=document.getElementById('acc-code').value, name=document.getElementById('acc-name').value;
  if(!code||!name){notify('أدخل الكود والاسم','error');return;}
  const editId=document.getElementById('edit-account-id').value;
  const balance=parseFloat(document.getElementById('acc-balance').value)||0;
  const data={code,name,type:document.getElementById('acc-type').value,debit:balance>0?balance:0,credit:balance<0?Math.abs(balance):0};
  if(editId)data.id=parseInt(editId);
  await dbPut('accounts',data);closeModal('account-modal');notify('تم حفظ الحساب');renderAccounts();
}

// ============ LEDGER ============
async function populateLedgerAccounts() {
  const accounts=await dbGetAll('accounts');
  const sel=document.getElementById('ledger-account');
  sel.innerHTML='<option value="">-- اختر حساب --</option>'+accounts.map(a=>`<option value="${a.id}">${a.code} - ${a.name}</option>`).join('');
}

async function renderLedger() {
  const accId=parseInt(document.getElementById('ledger-account')?.value);
  if(!accId)return;
  const account=await dbGet('accounts',accId);
  if(!account)return;
  const entries=await dbGetAll('journalEntries');
  const accounts=await dbGetAll('accounts');
  const accMap={};accounts.forEach(a=>accMap[a.id]=a);
  const relevant=entries.filter(e=>e.debitAccId===accId||e.creditAccId===accId);
  let bal=(account.debit||0)-(account.credit||0);
  const rows=relevant.map(e=>{
    const isDr=e.debitAccId===accId;
    const amt=parseFloat(e.amount)||0;
    if(isDr)bal+=amt;else bal-=amt;
    return `<div class="ledger-entry">
      <div>${e.date}</div><div>${e.desc}</div>
      <div style="color:var(--success);text-align:center;direction:ltr">${isDr?fmt(amt):'-'}</div>
      <div style="color:var(--danger);text-align:center;direction:ltr">${!isDr?fmt(amt):'-'}</div>
      <div style="font-weight:700;text-align:center;direction:ltr;color:${bal>=0?'var(--success)':'var(--danger)'}">${fmt(Math.abs(bal))}</div>
    </div>`;
  }).join('');
  document.getElementById('ledger-content').innerHTML=`
    <div style="margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--primary)">
      <div style="font-size:18px;font-weight:900;color:var(--primary)">${account.code} - ${account.name}</div>
    </div>
    <div class="ledger-entry ledger-header"><div>التاريخ</div><div>البيان</div><div style="text-align:center">مدين</div><div style="text-align:center">دائن</div><div style="text-align:center">الرصيد</div></div>
    <div class="ledger-entry" style="background:var(--bg-panel)">
      <div>${document.getElementById('ledger-from')?.value||''}</div><div style="font-weight:600">رصيد أول المدة</div>
      <div style="text-align:center;direction:ltr">${fmt(account.debit)}</div><div style="text-align:center;direction:ltr">${fmt(account.credit)}</div>
      <div style="font-weight:700;text-align:center;direction:ltr">${fmt((account.debit||0)-(account.credit||0))}</div>
    </div>
    ${rows||'<div style="padding:20px;text-align:center;color:var(--text-muted)">لا توجد حركات في هذه الفترة</div>'}
  `;
}

// ============ TRIAL BALANCE ============
async function renderTrialBalance() {
  const accounts=await dbGetAll('accounts');
  let td=0,tc=0;
  document.getElementById('trial-balance-body').innerHTML=accounts.map(a=>{
    td+=(a.debit||0);tc+=(a.credit||0);
    return `<tr><td>${a.code}</td><td>${a.name}</td><td style="direction:ltr">${a.debit?fmt(a.debit):'-'}</td><td style="direction:ltr">${a.credit?fmt(a.credit):'-'}</td></tr>`;
  }).join('');
  document.getElementById('trial-total-debit').textContent=fmt(td);
  document.getElementById('trial-total-credit').textContent=fmt(tc);
}

// ============ JOURNAL ENTRIES ============
async function renderJournalEntries() {
  const entries=await dbGetAll('journalEntries');
  const accounts=await dbGetAll('accounts');
  ['je-debit-acc','je-credit-acc'].forEach(id=>{
    const sel=document.getElementById(id);
    if(sel)sel.innerHTML='<option value="">-- اختر --</option>'+accounts.map(a=>`<option value="${a.id}">${a.code} - ${a.name}</option>`).join('');
  });
  document.getElementById('je-table-body').innerHTML=entries.length?entries.reverse().map(e=>`
    <tr><td>${e.id}</td><td>${e.date}</td><td>${e.desc}</td>
    <td style="color:var(--success);direction:ltr">$${fmt(e.amount)}</td>
    <td style="color:var(--danger);direction:ltr">$${fmt(e.amount)}</td>
    <td class="no-print"><button class="btn btn-sm btn-danger" onclick="dbDelete('journalEntries',${e.id}).then(renderJournalEntries)">🗑</button></td></tr>`).join(''):
    '<tr><td colspan="6"><div class="empty-state"><div class="icon">✏️</div><p>لا توجد قيود</p></div></td></tr>';
}

async function saveJournalEntry(){
  const dA=parseInt(document.getElementById('je-debit-acc').value);
  const cA=parseInt(document.getElementById('je-credit-acc').value);
  const amt=parseFloat(document.getElementById('je-amount').value)||0;
  if(!dA||!cA||!amt){notify('أكمل بيانات القيد','error');return;}
  await dbPut('journalEntries',{date:document.getElementById('je-date').value,desc:document.getElementById('je-desc').value,debitAccId:dA,creditAccId:cA,amount:amt});
  closeModal('je-modal');notify('تم حفظ القيد');renderJournalEntries();
}

// ============ VOUCHERS ============
async function renderVouchers(type) {
  const vouchers=await dbGetAll('vouchers');
  const filtered=vouchers.filter(v=>v.type===type).reverse();
  const bodyId=type==='receipt'?'receipts-history':'payments-history';
  const parties=['شركة الأمل التجارية','مؤسسة النجاح','شركة الخليج','محلات السعادة','مورد الإلكترونيات','مورد القرطاسية'];
  const selId=type==='receipt'?'rcpt-from':'pay-to';
  const sel=document.getElementById(selId);
  if(sel)sel.innerHTML='<option value="">-- اختر --</option>'+parties.map(p=>`<option>${p}</option>`).join('');
  const numId=type==='receipt'?'rcpt-num':'pay-num';
  const prefix=type==='receipt'?'RCV':'PAY';
  const numEl=document.getElementById(numId);
  if(numEl)numEl.value=`${prefix}-2026-${String(filtered.length+1).padStart(3,'0')}`;
  const el=document.getElementById(bodyId);
  if(el)el.innerHTML=filtered.slice(0,15).map(v=>`<tr><td style="font-size:11px;direction:ltr">${v.number}</td><td>${v.party}</td><td style="direction:ltr">$${fmt(v.amount)}</td><td>${v.date}</td></tr>`).join('')||'<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text-muted)">لا توجد سندات</td></tr>';
}

async function saveVoucher(type){
  const amtId=type==='receipt'?'rcpt-amount':'pay-amount';
  const partyId=type==='receipt'?'rcpt-from':'pay-to';
  const numId=type==='receipt'?'rcpt-num':'pay-num';
  const dateId=type==='receipt'?'rcpt-date':'pay-date';
  const methId=type==='receipt'?'rcpt-method':'pay-method';
  const descId=type==='receipt'?'rcpt-desc':'pay-desc';
  const amt=parseFloat(document.getElementById(amtId)?.value)||0;
  const party=document.getElementById(partyId)?.value;
  if(!amt||!party){notify('أكمل البيانات','error');return;}
  await dbPut('vouchers',{type,number:document.getElementById(numId)?.value,party,amount:amt,date:document.getElementById(dateId)?.value,method:document.getElementById(methId)?.value,desc:document.getElementById(descId)?.value});
  notify(`تم حفظ سند ${type==='receipt'?'القبض':'الصرف'}`);renderVouchers(type);
}

