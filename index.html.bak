<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<!-- Supabase Connection -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
  const SUPABASE_URL = 'https://mgrgideetxpvosutcokl.supabase.co'
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1ncmdpZGVldHhwdm9zdXRjb2tsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4OTQ3MTcsImV4cCI6MjA5MTQ3MDcxN30.ZQ5ldE-IBEMADRPJx5Ixd7ZIAmmJlUUB8h7z1C0gMmQ'
  const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY)

  // Test the connection
  async function testConnection() {
    const { data, error } = await supabaseClient.from('companies').select('*')
    if (error) {
      console.log('Connection error:', error.message)
    } else {
      console.log('Supabase connected successfully ✅', data)
    }
  }
  testConnection()
  // ============ AUTH ============
let currentUser = null;
let currentCompany = null;

async function loginUser() {
  const email = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;
  const btn = document.getElementById('login-btn');
  const errorEl = document.getElementById('login-error');

  if (!email || !password) {
    showLoginError('الرجاء إدخال البريد الإلكتروني وكلمة المرور');
    return;
  }

  btn.textContent = 'جاري تسجيل الدخول...';
  btn.disabled = true;
  errorEl.style.display = 'none';

  const { data, error } = await supabaseClient.auth.signInWithPassword({ email, password });

  if (error) {
    showLoginError('البريد الإلكتروني أو كلمة المرور غير صحيحة');
    btn.textContent = 'تسجيل الدخول';
    btn.disabled = false;
    return;
  }

  currentUser = data.user;
  await loadUserCompany();
}

async function loadUserCompany() {
  // First get the profile
  const { data: profile, error: profileError } = await supabaseClient
    .from('profiles')
    .select('*')
    .eq('id', currentUser.id)
    .single();

  if (profileError || !profile) {
    showLoginError('لم يتم العثور على بيانات المستخدم');
    return;
  }

  // Then get the company separately
  const { data: company, error: companyError } = await supabaseClient
    .from('companies')
    .select('*')
    .eq('id', profile.company_id)
    .single();

  if (companyError || !company) {
    showLoginError('لم يتم العثور على بيانات الشركة');
    return;
  }

  currentCompany = company;

  // Update top bar
  const nameEl = document.getElementById('topbar-company-name');
  if (nameEl) nameEl.textContent = company.name;

  const subtitleEl = document.getElementById('topbar-subtitle');
  if (subtitleEl) subtitleEl.textContent = company.address || '';

  // Update username
  const usernameEl = document.getElementById('topbar-username');
  if (usernameEl) usernameEl.textContent = profile.full_name || company.name;

  // Update avatar initials
  const avatarEl = document.querySelector('.user-avatar');
  if (avatarEl) {
    const initials = (profile.full_name || company.name)
      .split(' ')
      .map(w => w[0])
      .join('')
      .substring(0, 2)
      .toUpperCase();
    avatarEl.textContent = initials;
  }

  // Hide login show app
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app-wrapper').style.display = 'flex';

  // Build correct sidebar for this company
  buildSidebar(company.business_type);
  renderDashboard();
}

async function logoutUser() {
  await supabaseClient.auth.signOut();
  currentUser = null;
  currentCompany = null;
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('app-wrapper').style.display = 'none';
}

function showLoginError(msg) {
  const el = document.getElementById('login-error');
  el.textContent = msg;
  el.style.display = 'block';
}

// Check if already logged in on page load
async function checkSession() {
  // Always sign out first to clear any cached session
  await supabaseClient.auth.signOut();
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('app-wrapper').style.display = 'none';
}
function buildSidebar(businessType) {
  const menus = {
    barber: [
      { icon:'📊', label:'لوحة التحكم',     page:'dashboard' },
      { icon:'✂️', label:'الخدمات', page:'services' },
      { icon:'👥', label:'الموظفون',         page:'employees' },
      { icon:'📅', label:'الحجوزات',         page:'reservations' },
      { icon:'🧾', label:'فاتورة مبيع',      page:'invoices' },
      { icon:'📋', label:'سجل الفواتير',     page:'invoices-list' },
      { icon:'🧴', label:'المستلزمات',       page:'supplies' },
      { icon:'💡', label:'الفواتير الثابتة', page:'bills' },
      { icon:'💵', label:'سند قبض',          page:'receipt-voucher' },
      { icon:'💸', label:'سند صرف',          page:'payment-voucher' },
      { icon:'🏢', label:'بيانات الشركة',    page:'company-settings' },
    ],
    building_materials: [
      { icon:'🧾', label:'فاتورة مبيع',      page:'invoices' },
      { icon:'📋', label:'سجل الفواتير',     page:'invoices-list' },
      { icon:'↩️', label:'مرتجع مبيعات',    page:'sales-return' },
      { icon:'🛒', label:'فاتورة شراء',      page:'purchases' },
      { icon:'📋', label:'سجل المشتريات',    page:'purchases-list' },
      { icon:'↩️', label:'مرتجع مشتريات',   page:'purchases-return' },
      { icon:'📦', label:'أصناف',            page:'items' },
      { icon:'📒', label:'دليل الحسابات',    page:'accounts' },
      { icon:'🔍', label:'كشف حساب',         page:'account-ledger' },
      { icon:'⚖️', label:'ميزان المراجعة',   page:'trial-balance' },
      { icon:'✏️', label:'القيود المحاسبية', page:'journal-entries' },
      { icon:'💵', label:'سند قبض',          page:'receipt-voucher' },
      { icon:'💸', label:'سند صرف',          page:'payment-voucher' },
      { icon:'🏢', label:'بيانات الشركة',    page:'company-settings' },
    ],
    auto_parts: [
      { icon:'📊', label:'لوحة التحكم',      page:'dashboard' },
      { icon:'🧾', label:'فاتورة مبيع',      page:'invoices' },
      { icon:'📋', label:'سجل الفواتير',     page:'invoices-list' },
      { icon:'↩️', label:'مرتجع مبيعات',    page:'sales-return' },
      { icon:'📑', label:'طلبيات',           page:'orders' },
      { icon:'🛒', label:'فاتورة شراء',      page:'purchases' },
      { icon:'📋', label:'سجل المشتريات',    page:'purchases-list' },
      { icon:'↩️', label:'مرتجع مشتريات',   page:'purchases-return' },
      { icon:'📦', label:'أصناف',            page:'items' },
      { icon:'📈', label:'كشف المخزون',      page:'stock-report' },
      { icon:'🏭', label:'المخازن',          page:'warehouse' },
      { icon:'📒', label:'دليل الحسابات',    page:'accounts' },
      { icon:'🔍', label:'كشف حساب',         page:'account-ledger' },
      { icon:'⚖️', label:'ميزان المراجعة',   page:'trial-balance' },
      { icon:'✏️', label:'القيود المحاسبية', page:'journal-entries' },
      { icon:'💵', label:'سند قبض',          page:'receipt-voucher' },
      { icon:'💸', label:'سند صرف',          page:'payment-voucher' },
      { icon:'🏢', label:'بيانات الشركة',    page:'company-settings' },
    ],
  };

  const sidebar = document.querySelector('.sidebar');
  const items = menus[businessType] || menus['auto_parts'];

  // Rebuild sidebar
  sidebar.innerHTML = `
    <div class="sidebar-logo">
      <h2 id="sidebar-company-name">${currentCompany.name}</h2>
      <p id="sidebar-company-type">
        ${businessType === 'barber' ? 'صالون حلاقة' :
          businessType === 'auto_parts' ? 'قطع غيار سيارات' :
          businessType === 'building_materials' ? 'مواد بناء' : ''}
      </p>
    </div>
    <div class="period-badge" id="period-badge">
      01/01/${new Date().getFullYear()} — 31/12/${new Date().getFullYear()}
    </div>
    ${items.map(item => `
      <div class="nav-item" onclick="showPage('${item.page}')">
        <span class="nav-icon">${item.icon}</span>
        <span>${item.label}</span>
      </div>
    `).join('')}
    <div style="margin-top:auto;padding:16px;">
      <button onclick="logoutUser()" style="
        width:100%;padding:10px;
        background:rgba(255,255,255,0.06);
        border:1px solid rgba(255,255,255,0.1);
        border-radius:8px;color:rgba(255,255,255,0.6);
        cursor:pointer;font-family:'Cairo',sans-serif;
        font-size:13px;font-weight:600;">
        🚪 تسجيل الخروج
      </button>
    </div>
  `;

}
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CATALAN POS - نظام إدارة الأعمال</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #8B1A1A;
  --primary-dark: #5C1010;
  --primary-light: #C0392B;
  --accent: #D4A853;
  --accent-light: #F0C97A;
  --bg-main: #F5F0E8;
  --bg-card: #FDFAF5;
  --bg-sidebar: #1A0A0A;
  --bg-panel: #F0EAD8;
  --text-primary: #1A0A0A;
  --text-secondary: #5A4A3A;
  --text-muted: #9A8A7A;
  --border: #D8C8A8;
  --border-light: #EAD8B8;
  --success: #1B6B3A;
  --danger: #8B1A1A;
  --warning: #B8860B;
  --info: #1A4A6B;
  --shadow-sm: 0 2px 8px rgba(139,26,26,0.08);
  --shadow-md: 0 4px 20px rgba(139,26,26,0.12);
  --shadow-lg: 0 8px 40px rgba(139,26,26,0.16);
  --radius: 8px;
  --radius-lg: 14px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body { font-family: 'Cairo','Tajawal',sans-serif; background: var(--bg-main); color: var(--text-primary); height: 100vh; overflow: hidden; }
html[dir="ltr"] body { font-family: 'Segoe UI','Tajawal',sans-serif; }

/* numbers always english */
.num { font-variant-numeric: tabular-nums; font-feature-settings: "tnum"; unicode-bidi: embed; direction: ltr; display: inline-block; }

.app-wrapper { display: flex; height: 100vh; overflow: hidden; }
.sidebar { 
  width: 240px; 
  background: var(--bg-sidebar); 
  display: flex; 
  flex-direction: column; 
  flex-shrink: 0; 
  overflow-y: auto; 
  z-index: 100;
  height: 100vh;
  position: sticky;
  top: 0;
}
.sidebar-logo { padding: 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.08); }
.sidebar-logo h2 { color: var(--accent); font-size: 18px; font-weight: 900; letter-spacing: 1px; }
.sidebar-logo p { color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 2px; }
.period-badge { background: rgba(212,168,83,0.15); border: 1px solid rgba(212,168,83,0.3); border-radius: 6px; padding: 6px 10px; margin: 12px 16px; font-size: 11px; color: var(--accent-light); text-align: center; }
.nav-section-title { color: rgba(255,255,255,0.25); font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 14px 16px 6px; }
.nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 16px; color: rgba(255,255,255,0.6); cursor: pointer; transition: all 0.2s; font-size: 14px; font-weight: 500; border-right: 3px solid transparent; user-select: none; }
.nav-item:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.9); }
.nav-item.active { background: rgba(212,168,83,0.12); color: var(--accent); border-right-color: var(--accent); }
html[dir="ltr"] .nav-item { border-right: none; border-left: 3px solid transparent; }
html[dir="ltr"] .nav-item.active { border-left-color: var(--accent); }
.nav-icon { font-size: 16px; width: 20px; text-align: center; }
.main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.topbar { background: var(--bg-card); border-bottom: 1px solid var(--border); padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; box-shadow: var(--shadow-sm); }
.topbar-company { font-size: 22px; font-weight: 900; color: var(--primary); letter-spacing: -0.5px; }
.topbar-right { display: flex; align-items: center; gap: 12px; }
.lang-btns { display: flex; gap: 4px; }
.lang-btn { padding: 4px 10px; border: 1px solid var(--border); background: transparent; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; color: var(--text-secondary); font-family: 'Cairo',sans-serif; transition: all 0.15s; }
.lang-btn.active,.lang-btn:hover { background: var(--primary); color: white; border-color: var(--primary); }
.topbar-user { display: flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--bg-panel); border-radius: 8px; border: 1px solid var(--border); cursor: pointer; }
.user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
.page-content { flex: 1; overflow-y: auto; padding: 24px; background: var(--bg-main); }
.page-view { display: none; animation: fadeIn 0.2s ease; }
.page-view.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; box-shadow: var(--shadow-sm); }
.card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid var(--border-light); }
.card-title { font-size: 16px; font-weight: 700; color: var(--primary); display: flex; align-items: center; gap: 8px; }

.btn { padding: 9px 18px; border-radius: var(--radius); border: none; cursor: pointer; font-family: 'Cairo',sans-serif; font-size: 13px; font-weight: 600; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px; }
.btn-primary { background: var(--primary); color: white; }
.btn-primary:hover { background: var(--primary-dark); }
.btn-success { background: var(--success); color: white; }
.btn-success:hover { background: #145230; }
.btn-danger { background: var(--danger); color: white; }
.btn-danger:hover { background: #6B1010; }
.btn-warning { background: var(--warning); color: white; }
.btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text-secondary); }
.btn-outline:hover { border-color: var(--primary); color: var(--primary); }
.btn-accent { background: var(--accent); color: var(--bg-sidebar); }
.btn-accent:hover { background: var(--accent-light); }
.btn-sm { padding: 6px 12px; font-size: 12px; }
.btn-lg { padding: 12px 24px; font-size: 15px; }

.form-group { margin-bottom: 16px; }
.form-label { display: block; font-size: 13px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px; }
.form-control { width: 100%; padding: 9px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-family: 'Cairo',sans-serif; font-size: 14px; color: var(--text-primary); background: white; transition: border-color 0.2s; }
html[dir="rtl"] .form-control { direction: rtl; }
html[dir="ltr"] .form-control { direction: ltr; }
.form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(139,26,26,0.08); }
select.form-control { cursor: pointer; }

.table-wrapper { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th { background: var(--bg-panel); padding: 10px 14px; text-align: right; font-weight: 700; color: var(--primary); border-bottom: 2px solid var(--border); white-space: nowrap; }
html[dir="ltr"] thead th { text-align: left; }
tbody td { padding: 10px 14px; border-bottom: 1px solid var(--border-light); color: var(--text-primary); }
tbody tr:hover { background: rgba(212,168,83,0.04); }
tbody tr:last-child td { border-bottom: none; }

.stats-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(160px,1fr)); gap: 16px; margin-bottom: 24px; }
.stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 18px 20px; position: relative; overflow: hidden; }
.stat-card::before { content: ''; position: absolute; top: 0; right: 0; width: 4px; height: 100%; background: var(--primary); }
html[dir="ltr"] .stat-card::before { right: auto; left: 0; }
.stat-label { font-size: 12px; color: var(--text-muted); font-weight: 600; margin-bottom: 8px; }
.stat-value { font-size: 26px; font-weight: 900; color: var(--primary); line-height: 1; direction: ltr; }
.stat-sub { font-size: 11px; color: var(--text-muted); margin-top: 6px; }

.badge { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
.badge-success { background: #D4EDDA; color: #155724; }
.badge-danger { background: #F8D7DA; color: #721C24; }
.badge-warning { background: #FFF3CD; color: #856404; }
.badge-info { background: #D1ECF1; color: #0C5460; }
.badge-secondary { background: var(--bg-panel); color: var(--text-secondary); }

.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 1000; }
.modal-overlay.open { display: flex; }
.modal { background: var(--bg-card); border-radius: var(--radius-lg); width: 90%; max-width: 720px; max-height: 90vh; overflow-y: auto; box-shadow: var(--shadow-lg); }
.modal-header { padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: var(--bg-card); z-index: 10; }
.modal-title { font-size: 16px; font-weight: 700; color: var(--primary); }
.modal-close { cursor: pointer; font-size: 20px; color: var(--text-muted); background: none; border: none; line-height: 1; }
.modal-body { padding: 24px; }
.modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 10px; justify-content: flex-start; position: sticky; bottom: 0; background: var(--bg-card); }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
@media (max-width: 900px) { .grid-2,.grid-3,.grid-4 { grid-template-columns: 1fr; } }

/* ===== MOBILE RESPONSIVE ===== */
@media (max-width: 768px) {
  html, body { overflow: auto; height: auto; }
  .app-wrapper { flex-direction: column; height: auto; overflow: visible; }
  .sidebar {
    width: 100%;
    height: auto;
    position: relative;
    flex-direction: row;
    flex-wrap: wrap;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 8px 0;
    z-index: 200;
  }
  .sidebar-logo { display: none; }
  .period-badge { display: none; }
  .sidebar > div[style*="margin-top:auto"] { display: none; }
  .nav-item {
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    font-size: 10px;
    border-right: none !important;
    border-left: none !important;
    border-bottom: 3px solid transparent;
    white-space: nowrap;
    min-width: 60px;
    text-align: center;
  }
  .nav-item.active { border-bottom-color: var(--accent) !important; border-right: none !important; }
  .nav-icon { font-size: 20px; width: auto; }
  .main-content { width: 100%; overflow: visible; }
  .topbar { padding: 10px 14px; }
  .topbar-company { font-size: 16px; }
  .lang-btns { display: none; }
  .topbar-user span { display: none; }
  .page-content { padding: 12px; overflow: visible; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .stat-value { font-size: 18px; }
  .modal { width: 98%; max-width: 98vw; max-height: 95vh; }
  .ai-chat-window { width: 92vw; }
  html[dir="rtl"] .ai-chat-window { left: auto; right: 0; }
  html[dir="ltr"] .ai-chat-window { right: 0; left: auto; }
  .ledger-entry { grid-template-columns: 80px 1fr 80px 80px 80px; font-size: 11px; }
  table { font-size: 11px; }
  thead th, tbody td { padding: 7px 8px; }
  .btn { padding: 7px 12px; font-size: 12px; }
  .invoice-number { font-size: 20px; }
  .notification { right: 8px !important; left: 8px !important; top: 8px; }
  .page-view { min-height: 60vh; }
  .doc-print-header table { font-size: 11px; }
  /* Mobile logout button in topbar */
  .mobile-logout { display: flex !important; }
}
@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .nav-item { padding: 6px 7px; font-size: 9px; min-width: 50px; }
  .search-bar { flex-direction: column; }
}
.flex { display: flex; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-4 { margin-bottom: 16px; }
.text-muted { color: var(--text-muted); font-size: 13px; }

.invoice-number { font-size: 28px; font-weight: 900; color: var(--primary); text-align: center; padding: 12px; background: var(--bg-panel); border-radius: var(--radius); border: 2px solid var(--primary); letter-spacing: 2px; direction: ltr; }

.item-row { display: grid; grid-template-columns: 2fr 80px 110px 110px auto; gap: 8px; margin-bottom: 8px; align-items: center; }

.search-bar { display: flex; gap: 10px; margin-bottom: 20px; }
.search-bar .form-control { flex: 1; }

.notification { position: fixed; top: 20px; right: 260px; padding: 12px 20px; border-radius: var(--radius); font-size: 14px; font-weight: 600; box-shadow: var(--shadow-md); z-index: 2000; display: none; align-items: center; gap: 8px; }
html[dir="ltr"] .notification { right: auto; left: 260px; }
.notification.show { display: flex; }
.notification.success { background: #D4EDDA; color: #155724; border: 1px solid #C3E6CB; }
.notification.error { background: #F8D7DA; color: #721C24; border: 1px solid #F5C6CB; }

.loading-spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.mini-chart { height: 60px; display: flex; align-items: flex-end; gap: 4px; }
.mini-bar { flex: 1; background: var(--primary); border-radius: 3px 3px 0 0; opacity: 0.7; transition: opacity 0.2s; }
.mini-bar:hover { opacity: 1; }
.progress-bar-wrap { background: var(--bg-panel); border-radius: 20px; height: 8px; overflow: hidden; }
.progress-bar-fill { height: 100%; background: var(--primary); border-radius: 20px; }

.ledger-entry { display: grid; grid-template-columns: 100px 1fr 120px 120px 120px; gap: 0; border-bottom: 1px solid var(--border-light); }
.ledger-entry > div { padding: 9px 12px; font-size: 13px; }
.ledger-header { background: var(--bg-panel); font-weight: 700; color: var(--primary); }

.empty-state { text-align: center; padding: 48px 24px; color: var(--text-muted); }
.empty-state .icon { font-size: 48px; margin-bottom: 12px; }
.empty-state p { font-size: 15px; font-weight: 600; }

.ai-panel { position: fixed; z-index: 500; }
html[dir="ltr"] .ai-panel { left: 24px; bottom: 24px; }
html[dir="rtl"] .ai-panel { right: 24px; bottom: 24px; }
.ai-fab { width: 56px; height: 56px; border-radius: 50%; background: var(--primary); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 22px; box-shadow: var(--shadow-lg); transition: all 0.3s; color: white; }
.ai-fab:hover { background: var(--primary-dark); transform: scale(1.05); }
.ai-chat-window { position: absolute; bottom: 68px; width: 380px; max-height: 500px; background: var(--bg-card); border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-lg); display: none; flex-direction: column; overflow: hidden; }
html[dir="rtl"] .ai-chat-window { left: 0; right: auto; }
html[dir="ltr"] .ai-chat-window { right: 0; left: auto; }
.ai-chat-window.open { display: flex; }
.ai-chat-header { background: var(--primary); color: white; padding: 14px 16px; font-weight: 700; display: flex; align-items: center; justify-content: space-between; }
.ai-chat-messages { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; min-height: 200px; max-height: 320px; }
.ai-msg { padding: 10px 13px; border-radius: 10px; font-size: 13px; line-height: 1.6; max-width: 90%; }
.ai-msg.bot { background: var(--bg-panel); border: 1px solid var(--border-light); align-self: flex-start; color: var(--text-primary); }
.ai-msg.user { background: var(--primary); color: white; align-self: flex-end; text-align: right; }
.ai-chat-input-row { padding: 12px; border-top: 1px solid var(--border); display: flex; gap: 8px; }
.ai-chat-input-row input { flex: 1; padding: 9px 12px; border: 1px solid var(--border); border-radius: 8px; font-family: 'Cairo',sans-serif; font-size: 13px; }
html[dir="rtl"] .ai-chat-input-row input { direction: rtl; }
.ai-chat-input-row input:focus { outline: none; border-color: var(--primary); }

/* PRINT STYLES */
@media print {
  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
  .sidebar, .topbar, .ai-panel, .no-print { display: none !important; }
  .main-content { width: 100%; overflow: visible; }
  .page-content { padding: 0; overflow: visible; }
  .app-wrapper { display: block; height: auto; overflow: visible; }
  body { background: white; font-family: Arial, sans-serif; }
  .page-view.active { display: block !important; }
  .card { box-shadow: none !important; border: none !important; padding: 0 !important; margin: 0 !important; }

  /* PRINT INVOICE LAYOUT */
  .doc-print-header { display: block !important; }

  #doc-items-table { width: 100%; border-collapse: collapse; margin-top: 0; }
  #doc-items-table thead th {
    background: #e8e8e8 !important;
    border: 1px solid #999;
    padding: 5px 6px;
    font-size: 11px;
    font-weight: 700;
    text-align: center;
    color: #000;
  }
  #doc-items-table tbody td {
    border: 1px solid #999;
    padding: 4px 6px;
    font-size: 11px;
    text-align: center;
  }
  #doc-items-table tbody td:nth-child(3) { text-align: right; }

  /* Signature line */
  .print-signature { display: block !important; margin-top: 16px; font-size: 12px; }

  /* Hide screen-only elements */
  .btn, button, select, input[type="number"], input[type="date"], input[type="text"], textarea { display: none !important; }

  /* Show print totals */
  .print-totals-table { display: table !important; }
  .print-customer-info { display: block !important; }
  .grid-2 { display: block !important; }
  .card-header { display: none !important; }
  .form-group { display: none !important; }
}

.print-totals-table { display: none; }
.doc-print-header { display: none; }

code { font-size: 11px; background: var(--bg-panel); padding: 2px 6px; border-radius: 4px; direction: ltr; display: inline-block; }

/* ===== TYPEAHEAD SEARCH ===== */
.typeahead-wrap { position: relative; }
.typeahead-input { width: 100%; }
.typeahead-dropdown {
  position: absolute; top: 100%; left: 0; right: 0; z-index: 9999;
  background: white; border: 1px solid var(--primary);
  border-top: none; border-radius: 0 0 var(--radius) var(--radius);
  max-height: 200px; overflow-y: auto; display: none;
  box-shadow: var(--shadow-md);
}
.typeahead-dropdown.open { display: block; }
.typeahead-item {
  padding: 8px 12px; font-size: 13px; cursor: pointer;
  border-bottom: 1px solid var(--border-light);
  display: flex; justify-content: space-between; align-items: center;
}
.typeahead-item:hover, .typeahead-item.active { background: rgba(139,26,26,0.07); color: var(--primary); }
.typeahead-item .item-code { font-size: 11px; color: var(--text-muted); direction: ltr; }
.typeahead-item .item-price { font-size: 11px; color: var(--success); font-weight: 700; direction: ltr; }
</style>
</head>
<body>
<div class="notification" id="notification"></div>
<!-- LOGIN SCREEN -->
<div id="login-screen" style="
  position:fixed;inset:0;background:#F5F0E8;
  display:flex;align-items:center;justify-content:center;
  z-index:9999;font-family:'Cairo',sans-serif;">
  <div style="background:white;border-radius:16px;padding:40px;width:380px;box-shadow:0 8px 40px rgba(139,26,26,0.16);text-align:center;">
    
    <!-- Logo -->
    <div style="font-size:36px;font-weight:900;color:#8B1A1A;letter-spacing:2px;margin-bottom:4px;">CATALAN</div>
<div style="font-size:13px;color:#9A8A7A;margin-bottom:32px;">نظام إدارة الأعمال</div>

    <!-- Error message -->
    <div id="login-error" style="display:none;background:#F8D7DA;color:#721C24;padding:10px;border-radius:8px;font-size:13px;margin-bottom:16px;"></div>

    <!-- Email -->
    <div style="margin-bottom:16px;text-align:right;">
      <label style="display:block;font-size:13px;font-weight:600;color:#5A4A3A;margin-bottom:6px;">البريد الإلكتروني</label>
      <input id="login-email" type="email" 
        style="width:100%;padding:10px 12px;border:1px solid #D8C8A8;border-radius:8px;font-family:'Cairo',sans-serif;font-size:14px;direction:ltr;"
        placeholder="example@email.com">
    </div>

    <!-- Password -->
    <div style="margin-bottom:24px;text-align:right;">
      <label style="display:block;font-size:13px;font-weight:600;color:#5A4A3A;margin-bottom:6px;">كلمة المرور</label>
      <input id="login-password" type="password"
        style="width:100%;padding:10px 12px;border:1px solid #D8C8A8;border-radius:8px;font-family:'Cairo',sans-serif;font-size:14px;direction:ltr;"
        placeholder="••••••••"
        onkeydown="if(event.key==='Enter')loginUser()">
    </div>

    <!-- Button -->
    <button onclick="loginUser()" id="login-btn"
      style="width:100%;padding:12px;background:#8B1A1A;color:white;border:none;border-radius:8px;font-family:'Cairo',sans-serif;font-size:15px;font-weight:700;cursor:pointer;">
      تسجيل الدخول
    </button>

    <div style="margin-top:16px;font-size:11px;color:#9A8A7A;">
     CATALAN POS © 2026
    </div>
  </div>
</div>
<div class="app-wrapper" id="app-wrapper" style="display:none">
  <div class="sidebar">
    <div class="sidebar-logo">
      <h2 id="sidebar-company-name">POS</h2>
      <p id="sidebar-company-type">نظام إدارة الأعمال</p>
    </div>
    <div class="period-badge" id="period-badge">01/01/2026 — 31/12/2026</div>
  </div>

  <div class="main-content">
    <div class="topbar no-print">
      <div>
        <div class="topbar-company" id="topbar-company-name">CATALAN POS</div>
        <div style="font-size:11px;color:var(--text-muted);" id="topbar-subtitle"></div>
      </div>
      <div class="topbar-right">
        <div class="lang-btns">
          <button class="lang-btn" data-lang="FR" onclick="setLang('FR')">FRN</button>
          <button class="lang-btn active" data-lang="AR" onclick="setLang('AR')">ARB</button>
          <button class="lang-btn" data-lang="EN" onclick="setLang('EN')">ENG</button>
        </div>
        <div class="topbar-user">
          <div class="user-avatar">WT</div>
          <span style="font-size:13px;font-weight:600;" id="topbar-username">وجيه</span>
        </div>
        <button onclick="logoutUser()" style="display:none;padding:6px 10px;background:rgba(139,26,26,0.1);border:1px solid var(--border);border-radius:6px;cursor:pointer;font-size:12px;color:var(--primary)" class="mobile-logout">🚪</button>
      </div>
    </div>

    <div class="page-content">

      <!-- ===== DASHBOARD ===== -->
      <div class="page-view active" id="page-dashboard">
        <div class="flex-between mb-4 no-print">
          <div>
            <h1 style="font-size:22px;font-weight:900;color:var(--primary)" data-i18n="dashboard_title">لوحة التحكم</h1>
            <p class="text-muted">Thursday, April 09, 2026</p>
          </div>
          <button class="btn btn-primary" onclick="showPage('invoices')">➕ <span data-i18n="new_invoice_btn">فاتورة جديدة</span></button>
        </div>
        <div class="stats-grid" id="dashboard-stats"></div>
        <div class="grid-2">
          <div class="card">
            <div class="card-header"><div class="card-title">📊 <span data-i18n="sales_chart_title">مبيعات الأشهر الستة</span></div></div>
            <div class="mini-chart" id="sales-chart"></div>
            <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:11px;color:var(--text-muted)" id="chart-months"></div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">🔔 <span data-i18n="low_stock_title">أصناف منخفضة</span></div><button class="btn btn-sm btn-outline" onclick="showPage('items')" data-i18n="view_all">عرض الكل</button></div>
            <div id="low-stock-list"></div>
          </div>
        </div>
        <div class="grid-2 mt-4">
          <div class="card">
            <div class="card-header"><div class="card-title">🧾 <span data-i18n="recent_invoices_title">آخر الفواتير</span></div><button class="btn btn-sm btn-outline" onclick="showPage('invoices-list')" data-i18n="view_all">عرض الكل</button></div>
            <div id="recent-invoices-list"></div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">👥 <span data-i18n="top_customers_title">أكبر العملاء</span></div></div>
            <div id="top-customers-list"></div>
          </div>
        </div>
      </div>

      <!-- ===== ITEMS ===== -->
      <div class="page-view" id="page-items">
        <div class="flex-between mb-4 no-print">
          <h1 style="font-size:20px;font-weight:900;color:var(--primary)">📦 <span data-i18n="items_title">أصناف المخزون</span></h1>
          <button class="btn btn-primary" onclick="openItemModal()">➕ <span data-i18n="new_item_btn">صنف جديد</span></button>
        </div>
        <div class="card">
          <div class="search-bar no-print">
            <input class="form-control" id="item-search" placeholder="🔍 بحث باسم الصنف أو الكود..." oninput="renderItems()">
            <select class="form-control" style="width:180px" id="item-cat-filter" onchange="renderItems()"><option value="">كل الفئات</option></select>
            <button class="btn btn-outline" onclick="exportItemsCSV()">⬇ <span data-i18n="export_btn">تصدير</span></button>
          </div>
          <div class="table-wrapper">
            <table>
              <thead><tr><th data-i18n="th_code">كود</th><th data-i18n="th_name">اسم الصنف</th><th data-i18n="th_category">الفئة</th><th data-i18n="th_cost">سعر الشراء</th><th data-i18n="th_price">سعر البيع</th><th data-i18n="th_stock">المخزون</th><th data-i18n="th_min_stock">الحد الأدنى</th><th data-i18n="th_status">الحالة</th><th class="no-print" data-i18n="th_action">إجراء</th></tr></thead>
              <tbody id="items-table-body"></tbody>
            </table>
          </div>
        </div>
      </div>
      <!-- ===== SERVICES PAGE ===== -->
<div class="page-view" id="page-services">
  <div class="flex-between mb-4 no-print">
    <h1 style="font-size:20px;font-weight:900;color:var(--primary)">✂️ الخدمات</h1>
    <button class="btn btn-primary" onclick="openModal('service-modal')">➕ خدمة جديدة</button>
  </div>
  <div class="card">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>اسم الخدمة</th>
            <th>السعر الأساسي</th>
            <th>Junior $</th>
            <th>Senior $</th>
            <th>Master $</th>
            <th>المدة (دقيقة)</th>
            <th>الحالة</th>
            <th class="no-print">إجراء</th>
          </tr>
        </thead>
        <tbody id="services-table-body"></tbody>
      </table>
    </div>
  </div>
</div>
      <!-- ===== EMPLOYEES PAGE ===== -->
<div class="page-view" id="page-employees">
  <div class="flex-between mb-4 no-print">
    <h1 style="font-size:20px;font-weight:900;color:var(--primary)">👥 الموظفون</h1>
    <button class="btn btn-primary" onclick="openModal('employee-modal')">➕ موظف جديد</button>
  </div>
  <div class="stats-grid" id="employee-stats"></div>
  <div class="card">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>الاسم</th>
            <th>الهاتف</th>
            <th>المستوى</th>
            <th>نوع الراتب</th>
            <th>الراتب الأساسي</th>
            <th>العمولة %</th>
            <th>قطعات هذا الشهر</th>
            <th>المستحق هذا الشهر</th>
            <th>الحالة</th>
            <th class="no-print">إجراء</th>
          </tr>
        </thead>
        <tbody id="employees-table-body"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- ===== RESERVATIONS PAGE ===== -->
<div class="page-view" id="page-reservations">
  <div class="flex-between mb-4 no-print">
    <h1 style="font-size:20px;font-weight:900;color:var(--primary)">📅 الحجوزات</h1>
    <button class="btn btn-primary" onclick="openReservationModal()">➕ حجز جديد</button>
  </div>
  <div class="search-bar no-print">
    <input class="form-control" id="res-search" placeholder="🔍 بحث باسم العميل..." oninput="renderReservations()">
    <select class="form-control" style="width:160px" id="res-status-filter" onchange="renderReservations()">
      <option value="">كل الحالات</option>
      <option value="pending">قيد الانتظار</option>
      <option value="confirmed">مؤكد</option>
      <option value="done">منجز</option>
      <option value="cancelled">ملغى</option>
    </select>
    <input type="date" class="form-control" style="width:160px" id="res-date-filter" onchange="renderReservations()">
  </div>
  <div class="card">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>العميل</th>
            <th>الهاتف</th>
            <th>الخدمة</th>
            <th>الحلاق</th>
            <th>التاريخ</th>
            <th>الوقت</th>
            <th>السعر</th>
            <th>الحالة</th>
            <th class="no-print">إجراء</th>
          </tr>
        </thead>
        <tbody id="reservations-table-body"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- ===== SUPPLIES PAGE ===== -->
<div class="page-view" id="page-supplies">
  <div class="flex-between mb-4 no-print">
    <h1 style="font-size:20px;font-weight:900;color:var(--primary)">🧴 المستلزمات</h1>
    <button class="btn btn-primary" onclick="openModal('supply-modal')">➕ إضافة مستلزم</button>
  </div>
  <div class="stats-grid" id="supplies-stats"></div>
  <div class="card">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr><th>الاسم</th><th>الفئة</th><th>المبلغ</th><th>التاريخ</th><th>ملاحظات</th><th class="no-print">إجراء</th></tr>
        </thead>
        <tbody id="supplies-table-body"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- ===== BILLS PAGE ===== -->
<div class="page-view" id="page-bills">
  <div class="flex-between mb-4 no-print">
    <h1 style="font-size:20px;font-weight:900;color:var(--primary)">💡 الفواتير الثابتة</h1>
    <button class="btn btn-primary" onclick="openModal('bill-modal')">➕ فاتورة جديدة</button>
  </div>
  <div class="stats-grid" id="bills-stats"></div>
  <div class="card">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr><th>الاسم</th><th>المبلغ</th><th>تاريخ الاستحقاق</th><th>الشهر</th><th>الحالة</th><th class="no-print">إجراء</th></tr>
        </thead>
        <tbody id="bills-table-body"></tbody>
      </table>
    </div>
  </div>
</div>

      <!-- ===== INVOICE EDITOR (Sales, Returns, Orders, Purchases, PurchaseReturn) ===== -->
      <div class="page-view" id="page-invoices"><!-- Rendered dynamically --></div>
      <div class="page-view" id="page-sales-return"><!-- Rendered dynamically --></div>
      <div class="page-view" id="page-orders"><!-- Rendered dynamically --></div>
      <div class="page-view" id="page-purchases"><!-- Rendered dynamically --></div>
      <div class="page-view" id="page-purchases-return"><!-- Rendered dynamically --></div>

      <!-- ===== INVOICE LISTS ===== -->
      <div class="page-view" id="page-invoices-list">
        <div class="flex-between mb-4 no-print">
          <h1 style="font-size:20px;font-weight:900;color:var(--primary)">📋 <span data-i18n="invoices_list_title">سجل فواتير المبيع</span></h1>
          <button class="btn btn-primary" onclick="openDocPage('invoices')">➕ <span data-i18n="new_invoice_btn">فاتورة جديدة</span></button>
        </div>
        <div class="card"><div class="search-bar no-print"><input class="form-control" id="inv-search" placeholder="🔍 بحث برقم الفاتورة أو العميل..." oninput="renderInvoicesList()"></div>
          <div class="table-wrapper"><table><thead><tr><th>رقم</th><th>العميل</th><th>التاريخ</th><th>الاستحقاق</th><th>المجموع</th><th>الحالة</th><th class="no-print">إجراء</th></tr></thead><tbody id="invoices-list-body"></tbody></table></div>
        </div>
      </div>

      <div class="page-view" id="page-purchases-list">
        <div class="flex-between mb-4 no-print">
          <h1 style="font-size:20px;font-weight:900;color:var(--primary)">🛒 سجل المشتريات</h1>
          <button class="btn btn-primary" onclick="openDocPage('purchases')">➕ فاتورة شراء جديدة</button>
        </div>
        <div class="card"><div class="search-bar no-print"><input class="form-control" id="pur-search" placeholder="🔍 بحث..." oninput="renderPurchasesList()"></div>
          <div class="table-wrapper"><table><thead><tr><th>رقم</th><th>المورد</th><th>التاريخ</th><th>الاستحقاق</th><th>المجموع</th><th>الحالة</th><th class="no-print">إجراء</th></tr></thead><tbody id="purchases-list-body"></tbody></table></div>
        </div>
      </div>

      <!-- ===== STOCK REPORT ===== -->
      <div class="page-view" id="page-stock-report">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">📈 كشوفات الأصناف</h1><button class="btn btn-outline no-print" onclick="exportStockReport()">⬇ تصدير</button></div>
        <div class="stats-grid" id="stock-stats"></div>
        <div class="card"><div class="table-wrapper"><table><thead><tr><th>الكود</th><th>الصنف</th><th>المخزون الأولي</th><th>الوارد</th><th>الصادر</th><th>الرصيد الحالي</th><th>القيمة</th><th>الحالة</th></tr></thead><tbody id="stock-report-body"></tbody></table></div></div>
      </div>

      <!-- ===== WAREHOUSE ===== -->
      <div class="page-view" id="page-warehouse">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">🏭 المخازن</h1><button class="btn btn-primary" onclick="openModal('warehouse-modal')">➕ مخزن جديد</button></div>
        <div class="grid-3" id="warehouses-grid"></div>
      </div>

      <!-- ===== ACCOUNTS ===== -->
      <div class="page-view" id="page-accounts">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">📒 دليل الحسابات</h1><button class="btn btn-primary" onclick="openModal('account-modal')">➕ حساب جديد</button></div>
        <div class="card">
          <div class="search-bar no-print">
            <input class="form-control" id="account-search" placeholder="🔍 بحث..." oninput="renderAccounts()">
            <select class="form-control" style="width:180px" id="account-type-filter" onchange="renderAccounts()"><option value="">كل الأنواع</option><option value="asset">أصول</option><option value="liability">خصوم</option><option value="equity">حقوق الملكية</option><option value="revenue">إيرادات</option><option value="expense">مصاريف</option></select>
          </div>
          <div class="table-wrapper"><table><thead><tr><th>كود</th><th>اسم الحساب</th><th>النوع</th><th>الرصيد المدين</th><th>الرصيد الدائن</th><th>الرصيد</th><th class="no-print">إجراء</th></tr></thead><tbody id="accounts-table-body"></tbody></table></div>
        </div>
      </div>

      <!-- ===== ACCOUNT LEDGER ===== -->
      <div class="page-view" id="page-account-ledger">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">🔍 كشف حساب</h1><button class="btn btn-outline" onclick="window.print()">🖨 طباعة</button></div>
        <div class="card mb-4 no-print">
          <div class="grid-3">
            <div class="form-group"><label class="form-label">اختر الحساب</label><select class="form-control" id="ledger-account" onchange="renderLedger()"><option value="">-- اختر --</option></select></div>
            <div class="form-group"><label class="form-label">من تاريخ</label><input type="date" class="form-control" id="ledger-from" value="2026-01-01" onchange="renderLedger()"></div>
            <div class="form-group"><label class="form-label">إلى تاريخ</label><input type="date" class="form-control" id="ledger-to" value="2026-12-31" onchange="renderLedger()"></div>
          </div>
        </div>
        <div class="card" id="ledger-content"><div class="empty-state"><div class="icon">🔍</div><p>اختر حساباً لعرض الحركات</p></div></div>
      </div>

      <!-- ===== TRIAL BALANCE ===== -->
      <div class="page-view" id="page-trial-balance">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">⚖️ ميزان المراجعة</h1><div class="flex gap-2"><button class="btn btn-outline" onclick="window.print()">🖨 طباعة</button></div></div>
        <div class="card">
          <div style="text-align:center;padding:12px 0 20px;border-bottom:2px solid var(--primary);margin-bottom:20px">
            <div style="font-size:18px;font-weight:900;color:var(--primary)" id="trial-co-name">CATALAN POS</div>
            <div style="font-size:14px;color:var(--text-muted)">ميزان المراجعة — 01/01/2026 إلى 31/12/2026</div>
          </div>
          <div class="table-wrapper"><table><thead><tr><th>كود الحساب</th><th>اسم الحساب</th><th>مدين</th><th>دائن</th></tr></thead><tbody id="trial-balance-body"></tbody>
          <tfoot><tr style="background:var(--bg-panel);font-weight:900;color:var(--primary)"><td colspan="2" style="padding:12px 14px">الإجمالي</td><td style="padding:12px 14px" id="trial-total-debit">0.00</td><td style="padding:12px 14px" id="trial-total-credit">0.00</td></tr></tfoot></table></div>
        </div>
      </div>

      <!-- ===== JOURNAL ENTRIES ===== -->
      <div class="page-view" id="page-journal-entries">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">✏️ القيود المحاسبية</h1><button class="btn btn-primary" onclick="openModal('je-modal')">➕ قيد جديد</button></div>
        <div class="card"><div class="table-wrapper"><table><thead><tr><th>رقم</th><th>التاريخ</th><th>البيان</th><th>مدين</th><th>دائن</th><th class="no-print">إجراء</th></tr></thead><tbody id="je-table-body"></tbody></table></div></div>
      </div>

      <!-- ===== RECEIPT VOUCHER ===== -->
      <div class="page-view" id="page-receipt-voucher">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">💵 سند قبض</h1><button class="btn btn-primary" onclick="saveVoucher('receipt')">💾 حفظ السند</button></div>
        <div class="grid-2">
          <div class="card">
            <div class="card-header"><div class="card-title">بيانات سند القبض</div></div>
            <div class="form-group"><label class="form-label">رقم السند</label><input class="form-control" id="rcpt-num" readonly></div>
            <div class="form-group"><label class="form-label">التاريخ</label><input type="date" class="form-control" id="rcpt-date" value="2026-04-09"></div>
            <div class="form-group"><label class="form-label">المستلم من</label><select class="form-control" id="rcpt-from"><option value="">-- اختر --</option></select></div>
            <div class="form-group"><label class="form-label">المبلغ</label><input type="number" class="form-control" id="rcpt-amount" placeholder="0.00"></div>
            <div class="form-group"><label class="form-label">طريقة الدفع</label><select class="form-control" id="rcpt-method"><option>نقدي</option><option>شيك</option><option>تحويل بنكي</option></select></div>
            <div class="form-group"><label class="form-label">البيان</label><textarea class="form-control" id="rcpt-desc" rows="3"></textarea></div>
          </div>
          <div class="card"><div class="card-header"><div class="card-title">📋 سجل سندات القبض</div></div>
            <div class="table-wrapper"><table><thead><tr><th>رقم</th><th>من</th><th>المبلغ</th><th>التاريخ</th></tr></thead><tbody id="receipts-history"></tbody></table></div>
          </div>
        </div>
      </div>

      <!-- ===== PAYMENT VOUCHER ===== -->
      <div class="page-view" id="page-payment-voucher">
        <div class="flex-between mb-4 no-print"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">💸 سند صرف</h1><button class="btn btn-primary" onclick="saveVoucher('payment')">💾 حفظ السند</button></div>
        <div class="grid-2">
          <div class="card">
            <div class="card-header"><div class="card-title">بيانات سند الصرف</div></div>
            <div class="form-group"><label class="form-label">رقم السند</label><input class="form-control" id="pay-num" readonly></div>
            <div class="form-group"><label class="form-label">التاريخ</label><input type="date" class="form-control" id="pay-date" value="2026-04-09"></div>
            <div class="form-group"><label class="form-label">الصرف إلى</label><select class="form-control" id="pay-to"><option value="">-- اختر --</option></select></div>
            <div class="form-group"><label class="form-label">المبلغ</label><input type="number" class="form-control" id="pay-amount" placeholder="0.00"></div>
            <div class="form-group"><label class="form-label">طريقة الدفع</label><select class="form-control" id="pay-method"><option>نقدي</option><option>شيك</option><option>تحويل بنكي</option></select></div>
            <div class="form-group"><label class="form-label">البيان</label><textarea class="form-control" id="pay-desc" rows="3"></textarea></div>
          </div>
          <div class="card"><div class="card-header"><div class="card-title">📋 سجل سندات الصرف</div></div>
            <div class="table-wrapper"><table><thead><tr><th>رقم</th><th>إلى</th><th>المبلغ</th><th>التاريخ</th></tr></thead><tbody id="payments-history"></tbody></table></div>
          </div>
        </div>
      </div>

      <!-- ===== COMPANY SETTINGS ===== -->
      <div class="page-view" id="page-company-settings">
        <div class="flex-between mb-4"><h1 style="font-size:20px;font-weight:900;color:var(--primary)">🏢 معطيات الشركة</h1><button class="btn btn-primary" onclick="saveCompanySettings()">💾 حفظ الإعدادات</button></div>
        <div class="grid-2">
          <div class="card">
            <div class="card-header"><div class="card-title">📝 بيانات الشركة</div></div>
            <div class="form-group"><label class="form-label">اسم الشركة (عربي)</label><input class="form-control" id="co-name-ar" value="CATALAN POS"></div>
            <div class="form-group"><label class="form-label">اسم الشركة (إنجليزي)</label><input class="form-control" id="co-name-en" value="CATALAN POS"></div>
            <div class="form-group"><label class="form-label">العنوان</label><input class="form-control" id="co-address" value="بيروت - لبنان"></div>
            <div class="form-group"><label class="form-label">الهاتف</label><input class="form-control" id="co-phone" value="+961 01 315 219"></div>
            <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input class="form-control" id="co-email" value="hkm@pssleb.com"></div>
            <div class="form-group"><label class="form-label">الموقع الإلكتروني</label><input class="form-control" id="co-website" value="www.Pssleb.com"></div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">⚙️ إعدادات النظام</div></div>
            <div class="form-group"><label class="form-label">العملة الافتراضية</label><select class="form-control" id="co-currency"><option>USD - دولار أمريكي</option><option>LBP - ليرة لبنانية</option><option>EUR - يورو</option></select></div>
            <div class="form-group"><label class="form-label">نسبة الضريبة الافتراضية (%)</label><input type="number" class="form-control" id="co-tax" value="11"></div>
            <div class="form-group"><label class="form-label">بداية الفترة المحاسبية</label><input type="date" class="form-control" id="co-period-start" value="2026-01-01"></div>
            <div class="form-group"><label class="form-label">نهاية الفترة المحاسبية</label><input type="date" class="form-control" id="co-period-end" value="2026-12-31"></div>
            <div class="form-group"><label class="form-label">رقم الرجيستر</label><input class="form-control" id="co-reg" value="57K250126SAT-PI"></div>
          </div>
        </div>
      </div>

    </div><!-- end page-content -->
  </div><!-- end main-content -->
</div>
<!-- SERVICE MODAL -->
<div class="modal-overlay" id="service-modal">
  <div class="modal" style="max-width:500px">
    <div class="modal-header">
      <div class="modal-title" id="service-modal-title">✂️ خدمة جديدة</div>
      <button class="modal-close" onclick="closeModal('service-modal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-service-id">
      <div class="form-group">
        <label class="form-label">اسم الخدمة</label>
        <input class="form-control" id="svc-name" placeholder="مثال: قصة شعر">
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label class="form-label">السعر الأساسي ($)</label>
          <input type="number" class="form-control" id="svc-base-price" value="0" step="0.01">
        </div>
        <div class="form-group">
          <label class="form-label">المدة (دقيقة)</label>
          <input type="number" class="form-control" id="svc-duration" value="30">
        </div>
        <div class="form-group">
          <label class="form-label">سعر Junior ($)</label>
          <input type="number" class="form-control" id="svc-junior-price" value="0" step="0.01">
        </div>
        <div class="form-group">
          <label class="form-label">سعر Senior ($)</label>
          <input type="number" class="form-control" id="svc-senior-price" value="0" step="0.01">
        </div>
        <div class="form-group">
          <label class="form-label">سعر Master ($)</label>
          <input type="number" class="form-control" id="svc-master-price" value="0" step="0.01">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="saveService()">💾 حفظ</button>
      <button class="btn btn-outline" onclick="closeModal('service-modal')">إلغاء</button>
    </div>
  </div>
</div>
<!-- EMPLOYEE MODAL -->
<div class="modal-overlay" id="employee-modal">
  <div class="modal" style="max-width:500px">
    <div class="modal-header">
      <div class="modal-title" id="employee-modal-title">➕ موظف جديد</div>
      <button class="modal-close" onclick="closeModal('employee-modal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-employee-id">
      <div class="grid-2">
        <div class="form-group"><label class="form-label">الاسم</label><input class="form-control" id="emp-name"></div>
        <div class="form-group"><label class="form-label">الهاتف</label><input class="form-control" id="emp-phone"></div>
        <div class="form-group"><label class="form-label">المستوى</label>
          <select class="form-control" id="emp-level">
            <option value="junior">Junior</option>
            <option value="senior">Senior</option>
            <option value="master">Master</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">نوع الراتب</label>
          <select class="form-control" id="emp-salary-type" onchange="toggleSalaryFields()">
            <option value="commission">عمولة فقط</option>
            <option value="salary_commission">راتب + عمولة</option>
            <option value="salary">راتب ثابت</option>
          </select>
        </div>
        <div class="form-group" id="base-salary-group">
          <label class="form-label">الراتب الأساسي ($)</label>
          <input type="number" class="form-control" id="emp-base-salary" value="0">
        </div>
        <div class="form-group" id="commission-group">
          <label class="form-label">نسبة العمولة (%)</label>
          <input type="number" class="form-control" id="emp-commission" value="50" min="0" max="100">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="saveEmployee()">💾 حفظ</button>
      <button class="btn btn-outline" onclick="closeModal('employee-modal')">إلغاء</button>
    </div>
  </div>
</div>

<!-- RESERVATION MODAL -->
<div class="modal-overlay" id="reservation-modal">
  <div class="modal" style="max-width:550px">
    <div class="modal-header">
      <div class="modal-title" id="reservation-modal-title">📅 حجز جديد</div>
      <button class="modal-close" onclick="closeModal('reservation-modal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-reservation-id">
      <div class="grid-2">
        <div class="form-group"><label class="form-label">اسم العميل</label><input class="form-control" id="res-customer-name"></div>
        <div class="form-group"><label class="form-label">هاتف العميل</label><input class="form-control" id="res-customer-phone"></div>
        <div class="form-group"><label class="form-label">الخدمة</label>
          <select class="form-control" id="res-service" onchange="updateReservationPrice()">
            <option value="">-- اختر خدمة --</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">الحلاق</label>
          <select class="form-control" id="res-employee" onchange="updateReservationPrice()">
            <option value="">-- اختر حلاق --</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">التاريخ</label>
          <input type="date" class="form-control" id="res-date">
        </div>
        <div class="form-group"><label class="form-label">الوقت</label>
          <input type="time" class="form-control" id="res-time">
        </div>
        <div class="form-group"><label class="form-label">السعر ($)</label>
          <input type="number" class="form-control" id="res-price" value="0" step="0.01">
        </div>
        <div class="form-group"><label class="form-label">الحالة</label>
          <select class="form-control" id="res-status">
            <option value="pending">قيد الانتظار</option>
            <option value="confirmed">مؤكد</option>
            <option value="done">منجز</option>
            <option value="cancelled">ملغى</option>
          </select>
        </div>
      </div>
      <div class="form-group"><label class="form-label">ملاحظات</label>
        <textarea class="form-control" id="res-notes" rows="2"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="saveReservation()">💾 حفظ</button>
      <button class="btn btn-outline" onclick="closeModal('reservation-modal')">إلغاء</button>
    </div>
  </div>
</div>

