<!-- ACCOUNT MODAL -->
<div class="modal-overlay" id="account-modal">
  <div class="modal" style="max-width:500px">
    <div class="modal-header"><div class="modal-title">➕ حساب جديد</div><button class="modal-close" onclick="closeModal('account-modal')">✕</button></div>
    <div class="modal-body">
      <input type="hidden" id="edit-account-id">
      <div class="grid-2">
        <div class="form-group"><label class="form-label">كود الحساب</label><input class="form-control" id="acc-code" placeholder="1001"></div>
        <div class="form-group"><label class="form-label">اسم الحساب</label><input class="form-control" id="acc-name"></div>
        <div class="form-group"><label class="form-label">نوع الحساب</label><select class="form-control" id="acc-type"><option value="asset">أصول</option><option value="liability">خصوم</option><option value="equity">حقوق الملكية</option><option value="revenue">إيرادات</option><option value="expense">مصاريف</option></select></div>
        <div class="form-group"><label class="form-label">الرصيد الافتتاحي ($)</label><input type="number" class="form-control" id="acc-balance" value="0" step="0.01"></div>
      </div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary" onclick="saveAccount()">💾 حفظ</button><button class="btn btn-outline" onclick="closeModal('account-modal')">إلغاء</button></div>
  </div>
</div>

<!-- JOURNAL ENTRY MODAL -->
<div class="modal-overlay" id="je-modal">
  <div class="modal" style="max-width:500px">
    <div class="modal-header"><div class="modal-title">➕ قيد محاسبي جديد</div><button class="modal-close" onclick="closeModal('je-modal')">✕</button></div>
    <div class="modal-body">
      <div class="grid-2">
        <div class="form-group"><label class="form-label">التاريخ</label><input type="date" class="form-control" id="je-date" value="2026-04-09"></div>
        <div class="form-group"><label class="form-label">البيان</label><input class="form-control" id="je-desc"></div>
        <div class="form-group"><label class="form-label">الحساب المدين</label><select class="form-control" id="je-debit-acc"></select></div>
        <div class="form-group"><label class="form-label">الحساب الدائن</label><select class="form-control" id="je-credit-acc"></select></div>
        <div class="form-group"><label class="form-label">المبلغ ($)</label><input type="number" class="form-control" id="je-amount" value="0" step="0.01"></div>
      </div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary" onclick="saveJournalEntry()">💾 حفظ</button><button class="btn btn-outline" onclick="closeModal('je-modal')">إلغاء</button></div>
  </div>
</div>

<!-- WAREHOUSE MODAL -->
<div class="modal-overlay" id="warehouse-modal">
  <div class="modal" style="max-width:400px">
    <div class="modal-header"><div class="modal-title">➕ مخزن جديد</div><button class="modal-close" onclick="closeModal('warehouse-modal')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">اسم المخزن</label><input class="form-control" id="wh-name"></div>
      <div class="form-group"><label class="form-label">الموقع</label><input class="form-control" id="wh-location"></div>
      <div class="form-group"><label class="form-label">المسؤول</label><input class="form-control" id="wh-manager"></div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary" onclick="saveWarehouse()">💾 حفظ</button><button class="btn btn-outline" onclick="closeModal('warehouse-modal')">إلغاء</button></div>
  </div>
</div>

<!-- AI ASSISTANT -->
<div class="ai-panel no-print">
  <div class="ai-chat-window" id="ai-window">
    <div class="ai-chat-header"><div>🤖 NABCO AI Assistant</div><button onclick="toggleAI()" style="background:none;border:none;color:white;cursor:pointer;font-size:16px">✕</button></div>
    <div class="ai-chat-messages" id="ai-messages">
      <div class="ai-msg bot">مرحباً! أنا مساعدك الذكي لنظام NABCO.<br><br>• 🔍 البحث عن أي صنف في السوق<br>• 📊 تحليل بيانات المخزون<br>• 💡 اقتراح موردين<br>• 📋 مساعدة في الفواتير<br><br>كيف يمكنني مساعدتك؟</div>
    </div>
    <div class="ai-chat-input-row">
      <input type="text" id="ai-input" placeholder="اكتب سؤالك هنا..." onkeydown="if(event.key==='Enter')sendAIMessage()">
      <button class="btn btn-primary btn-sm" onclick="sendAIMessage()">إرسال</button>
    </div>
  </div>
  <button class="ai-fab" onclick="toggleAI()">🤖</button>
</div>

<script>
// ============ CONFIG ============
const DOC_TYPES = {
  invoices:          { label_ar:'فاتورة مبيع',      label_en:'Sales Invoice',      prefix:'INV', store:'invoices',      partyLabel_ar:'العميل',  partyLabel_en:'Customer',  icon:'🧾', parties:['شركة الأمل التجارية','مؤسسة النجاح','شركة الخليج','محلات السعادة','مجموعة الفجر','التجارية للأعمال'] },
  'sales-return':    { label_ar:'مرتجع مبيعات',     label_en:'Sales Return',       prefix:'SR',  store:'salesReturns',  partyLabel_ar:'العميل',  partyLabel_en:'Customer',  icon:'↩️', parties:['شركة الأمل التجارية','مؤسسة النجاح','شركة الخليج','محلات السعادة'] },
  orders:            { label_ar:'طلبية',             label_en:'Order',              prefix:'ORD', store:'orders',        partyLabel_ar:'العميل',  partyLabel_en:'Customer',  icon:'📑', parties:['شركة الأمل التجارية','مؤسسة النجاح','شركة الخليج','محلات السعادة'] },
  purchases:         { label_ar:'فاتورة شراء',       label_en:'Purchase Invoice',   prefix:'PUR', store:'purchases',     partyLabel_ar:'المورد',  partyLabel_en:'Supplier',  icon:'🛒', parties:['مورد الإلكترونيات','مورد القرطاسية','مورد الأثاث','مورد المعدات'] },
  'purchases-return':{ label_ar:'مرتجع مشتريات',    label_en:'Purchase Return',    prefix:'PR',  store:'purchReturns',  partyLabel_ar:'المورد',  partyLabel_en:'Supplier',  icon:'↩️', parties:['مورد الإلكترونيات','مورد القرطاسية','مورد الأثاث'] },
};

// current editing state
let currentDocType = 'invoices';
let currentDocId = null; // null = new
let docItems = [];

let currentLang = localStorage.getItem('catalan_lang') || 'AR';

// ============ INDEXEDDB ============
const DB_NAME = 'NABCOdb2';
const DB_VER = 2;
let db;

function initDB() {
  return new Promise((res, rej) => {
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      const stores = ['items','accounts','invoices','salesReturns','orders','purchases','purchReturns','journalEntries','vouchers','warehouses','settings'];
      stores.forEach(s => { if (!d.objectStoreNames.contains(s)) d.createObjectStore(s, { keyPath: 'id', autoIncrement: true }); });
    };
    req.onsuccess = e => { db = e.target.result; res(db); };
    req.onerror = rej;
  });
}
function dbGet(store, id) { return new Promise((res,rej) => { const tx = db.transaction(store,'readonly'); tx.objectStore(store).get(id).onsuccess = e => res(e.target.result); tx.onerror = rej; }); }
function dbGetAll(store) { return new Promise((res,rej) => { const tx = db.transaction(store,'readonly'); tx.objectStore(store).getAll().onsuccess = e => res(e.target.result); tx.onerror = rej; }); }
function dbPut(store, data) { return new Promise((res,rej) => { const tx = db.transaction(store,'readwrite'); tx.objectStore(store).put(data).onsuccess = e => res(e.target.result); tx.onerror = rej; }); }
function dbDelete(store, id) { return new Promise((res,rej) => { const tx = db.transaction(store,'readwrite'); tx.objectStore(store).delete(id).onsuccess = () => res(); tx.onerror = rej; }); }

// ============ SEED DATA ============
async function seedData() {
  const items = await dbGetAll('items');
  if (!items.length) {
    const seed = [
      { code:'ITM-001',name:'لاب توب Dell XPS 15',category:'إلكترونيات',unit:'قطعة',cost:1200,price:1500,stock:25,minStock:5,desc:'لاب توب احترافي' },
      { code:'ITM-002',name:'طابعة HP LaserJet',category:'إلكترونيات',unit:'قطعة',cost:280,price:350,stock:12,minStock:3,desc:'طابعة ليزر' },
      { code:'ITM-003',name:'ورق A4 (ريمة)',category:'قرطاسية',unit:'ريمة',cost:4,price:6,stock:200,minStock:50,desc:'ورق طباعة' },
      { code:'ITM-004',name:'أحبار طابعة HP',category:'قرطاسية',unit:'قطعة',cost:15,price:25,stock:4,minStock:10,desc:'خراطيش حبر' },
      { code:'ITM-005',name:'شاشة Samsung 24"',category:'إلكترونيات',unit:'قطعة',cost:180,price:230,stock:8,minStock:3,desc:'شاشة IPS FHD' },
      { code:'ITM-006',name:'كرسي مكتبي',category:'أثاث',unit:'قطعة',cost:90,price:140,stock:15,minStock:5,desc:'كرسي مريح' },
      { code:'ITM-007',name:'ماوس لوجيتك',category:'إلكترونيات',unit:'قطعة',cost:20,price:35,stock:30,minStock:10,desc:'ماوس لاسلكي' },
      { code:'ITM-008',name:'USB Flash 32GB',category:'إلكترونيات',unit:'قطعة',cost:8,price:14,stock:2,minStock:15,desc:'ذاكرة USB' },
    ];
    for (const it of seed) await dbPut('items', it);
  }
  const accounts = await dbGetAll('accounts');
  if (!accounts.length) {
    const accs = [
      { code:'1001',name:'الصندوق',type:'asset',debit:45000,credit:0 },
      { code:'1002',name:'البنك',type:'asset',debit:120000,credit:0 },
      { code:'1100',name:'المدينون',type:'asset',debit:35000,credit:0 },
      { code:'1200',name:'المخزون',type:'asset',debit:80000,credit:0 },
      { code:'2001',name:'الدائنون',type:'liability',debit:0,credit:28000 },
      { code:'2100',name:'قروض قصيرة الأجل',type:'liability',debit:0,credit:15000 },
      { code:'3001',name:'رأس المال',type:'equity',debit:0,credit:200000 },
      { code:'4001',name:'إيرادات المبيعات',type:'revenue',debit:0,credit:95000 },
      { code:'5001',name:'تكلفة البضاعة المباعة',type:'expense',debit:62000,credit:0 },
      { code:'5100',name:'مصاريف إدارية',type:'expense',debit:8500,credit:0 },
      { code:'5200',name:'مصاريف التسويق',type:'expense',debit:3200,credit:0 },
    ];
    for (const a of accs) await dbPut('accounts', a);
  }
  const invoices = await dbGetAll('invoices');
  if (!invoices.length) {
    const customers = ['شركة الأمل التجارية','مؤسسة النجاح','شركة الخليج','محلات السعادة','مجموعة الفجر'];
    for (let i = 1; i <= 8; i++) {
      const sub = i * 850 + 200;
      await dbPut('invoices', {
        number:`INV-2026-00${i}`, party:customers[i%customers.length],
        date:`2026-0${Math.ceil(i/2)}-${String(i*3).padStart(2,'0')}`,
        dueDate:'2026-05-30', warehouse:'المخزن الرئيسي',
        subtotal:sub, discount:5, tax:11, total:+(sub*0.95*1.11).toFixed(2),
        status: i%3===0?'unpaid':'paid', notes:'', items:[],
      });
    }
  }
  const warehouses = await dbGetAll('warehouses');
  if (!warehouses.length) {
    await dbPut('warehouses', { name:'المخزن الرئيسي',location:'بيروت - الأشرفية',manager:'وجيه' });
    await dbPut('warehouses', { name:'مخزن فرعي',location:'بيروت - الحمرا',manager:'أحمد' });
  }
}

// ============ NAV ============
function showPage(page) {
  document.querySelectorAll('.page-view').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');
  const nav = Array.from(document.querySelectorAll('.nav-item')).find(n => (n.getAttribute('onclick')||'').includes("'"+page+"'"));
  if (nav) nav.classList.add('active');
  switch(page) {
    case 'dashboard': renderDashboard(); break;
    case 'items': renderItems(); break;
    case 'invoices': openDocPage('invoices'); break;
    case 'sales-return': openDocPage('sales-return'); break;
    case 'orders': openDocPage('orders'); break;
    case 'purchases': openDocPage('purchases'); break;
    case 'purchases-return': openDocPage('purchases-return'); break;
    case 'invoices-list': renderInvoicesList(); break;
    case 'purchases-list': renderPurchasesList(); break;
    case 'stock-report': renderStockReport(); break;
    case 'warehouse': renderWarehouses(); break;
    case 'accounts': renderAccounts(); break;
    case 'account-ledger': populateLedgerAccounts(); renderLedger(); break;
    case 'trial-balance': renderTrialBalance(); break;
    case 'journal-entries': renderJournalEntries(); break;
    case 'receipt-voucher': renderVouchers('receipt'); break;
    case 'payment-voucher': renderVouchers('payment'); break;
    case 'employees': renderEmployees(); break;
case 'reservations': renderReservations(); break;
case 'supplies': renderSupplies(); break;
case 'bills': renderBills(); break;
case 'services': renderServices(); break;
  }
}

// ============ MODALS ============
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m => m.addEventListener('click', e => { if(e.target===m) m.classList.remove('open'); }));

// ============ NOTIFY ============
function notify(msg, type='success') {
  const n = document.getElementById('notification');
  n.textContent = (type==='success'?'✅ ':'❌ ')+msg;
  n.className = `notification ${type} show`;
  setTimeout(()=>n.classList.remove('show'),3000);
}

// ============ FORMAT ============
// All numbers rendered in English (Western Arabic) digits
function fmt(n, dec=2) {
  const num = parseFloat(n||0);
  return num.toLocaleString('en-US', { minimumFractionDigits: dec, maximumFractionDigits: dec });
}
function fmtInt(n) { return parseInt(n||0).toLocaleString('en-US'); }

// ============ DOCUMENT EDITOR (universal for all doc types) ============
async function openDocPage(type, editId=null) {
  currentDocType = type;
  currentDocId = editId;
  docItems = [];

  const cfg = DOC_TYPES[type];
  const store = cfg.store;
  const isEdit = editId !== null;

  // Load existing or create new
  let doc = null;
  if (isEdit) {
    doc = await dbGet(store, editId);
  }

  // Generate number
  let docNumber;
  if (isEdit && doc) {
    docNumber = doc.number;
  } else {
    const all = await dbGetAll(store);
    docNumber = `${cfg.prefix}-2026-${String(all.length+1).padStart(3,'0')}`;
  }

  // Load items list
  const allItems = await dbGetAll('items');
  _allItemsCache = allItems;

  // Pre-fill doc items
  if (isEdit && doc && doc.items && doc.items.length) {
    docItems = doc.items.map(it => ({...it}));
  }

  const lang = currentLang;
  const lbl = lang==='AR' ? cfg.label_ar : cfg.label_en;
  const partyLbl = lang==='AR' ? cfg.partyLabel_ar : cfg.partyLabel_en;

  const partyOptions = cfg.parties.map(p => `<option ${doc&&doc.party===p?'selected':''}>${p}</option>`).join('');

  const itemRowsHtml = (docItems.length ? docItems : [null]).map((di,idx) => buildItemRowHtml(idx, allItems, di)).join('');

  const pageEl = document.getElementById('page-' + type);

  // Build print header
  const coName = document.getElementById('co-name-ar')?.value || 'CATALAN POS';
  const coAddress = document.getElementById('co-address')?.value || 'بيروت - لبنان';
  const coPhone = document.getElementById('co-phone')?.value || '';

  pageEl.innerHTML = `
    <div class="doc-print-header">
  <table style="width:100%;border-collapse:collapse;border:1px solid #ccc;margin-bottom:0">
    <tr>
      <td style="width:55%;vertical-align:top;padding:10px 12px;border-right:1px solid #ccc">
        <div style="font-size:16px;font-weight:900;color:#000" id="print-co-name">${currentCompany?.name || 'CATALAN POS'}</div>
        <div style="font-size:11px;margin-top:6px;color:#333" id="print-co-address">${currentCompany?.address || ''}</div>
        <div style="font-size:11px;color:#333" id="print-co-phone">${currentCompany?.phone || ''}</div>
        <div style="margin-top:10px">
          <table style="border-collapse:collapse;border:1px solid #ccc;width:100%">
            <tr><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px;white-space:nowrap">Acc. No. : <strong id="print-acc-no">${currentCompany?.acc_no || '4100026'}</strong></td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px">VAT # : <span id="print-vat"></span></td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px">Order No. :</td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px;font-weight:700">Ref. No.: <strong id="print-ref">${docNumber}</strong></td></tr>
            <tr><td colspan="3" style="border:1px solid #ccc;padding:6px 7px;font-size:13px;font-weight:700;text-align:center" id="print-customer">${doc?doc.party:''}</td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px">Date : <strong id="print-date">${doc?doc.date:''}</strong></td></tr>
            <tr><td colspan="3" style="border:1px solid #ccc;padding:3px 7px;font-size:11px"></td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px">V.Date : <strong>${doc?doc.dueDate:''}</strong></td></tr>
            <tr><td colspan="3" style="border:1px solid #ccc;padding:3px 7px;font-size:11px"></td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px">Rate : <strong>${currentCompany?.rate || '89,000'}</strong></td></tr>
            <tr><td colspan="3" style="border:1px solid #ccc;padding:3px 7px;font-size:11px"></td><td style="border:1px solid #ccc;padding:3px 7px;font-size:11px">Sales Man : <strong>USER_1</strong></td></tr>
          </table>
        </div>
      </td>
      <td style="width:45%;vertical-align:top;padding:10px 12px">
        <div style="text-align:center;font-size:18px;font-weight:900;color:#000;border-bottom:2px solid #000;padding-bottom:8px;margin-bottom:8px">مبيع بالحساب</div>
        <table style="width:100%;border-collapse:collapse">
          <tr><td style="font-size:11px;padding:3px 0">Page : 1/1</td><td style="font-size:11px;text-align:right;padding:3px 0">Currency : <strong>USD</strong></td></tr>
          <tr><td style="font-size:11px;padding:3px 0">Time : ${new Date().toTimeString().slice(0,8)}</td><td style="font-size:11px;text-align:right;padding:3px 0"></td></tr>
        </table>
      </td>
    </tr>
  </table>
</div>

    <div class="flex-between mb-4 no-print">
      <h1 style="font-size:20px;font-weight:900;color:var(--primary)">${cfg.icon} ${lbl}</h1>
      <div class="flex gap-2">
        <button class="btn btn-outline" onclick="window.print()">🖨 طباعة</button>
        <button class="btn btn-success" onclick="saveDoc()">💾 حفظ</button>
      </div>
    </div>

    <div class="grid-2">
      <div class="card">
        <div class="card-header"><div class="card-title">📋 معلومات المستند</div></div>
        <div class="form-group">
          <label class="form-label">رقم المستند</label>
          <div class="invoice-number" id="doc-number">${docNumber}</div>
        </div>
        <div class="form-group">
          <label class="form-label">${partyLbl}</label>
          <div class="typeahead-wrap">
            <input class="form-control typeahead-input" id="doc-party" placeholder="اكتب اسم العميل أو كوده..."
              value="${doc?doc.party:''}"
              oninput="partyTypeaheadSearch()"
              onkeydown="partyTypeaheadKey(event)"
              autocomplete="off">
            <div class="typeahead-dropdown" id="party-dd"></div>
          </div>
        </div>
        <div class="grid-2">
          <div class="form-group">
            <label class="form-label">التاريخ</label>
            <input type="date" class="form-control" id="doc-date" value="${doc?doc.date:'2026-04-09'}">
          </div>
          <div class="form-group">
            <label class="form-label">تاريخ الاستحقاق</label>
            <input type="date" class="form-control" id="doc-due" value="${doc?doc.dueDate:'2026-05-09'}">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">المخزن</label>
          <select class="form-control" id="doc-warehouse">
            <option ${doc&&doc.warehouse==='المخزن الرئيسي'?'selected':''}>المخزن الرئيسي</option>
            <option ${doc&&doc.warehouse==='مخزن فرعي'?'selected':''}>مخزن فرعي</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">الحالة</label>
          <select class="form-control" id="doc-status">
            <option value="unpaid" ${doc&&doc.status==='unpaid'?'selected':''}>غير مدفوعة</option>
            <option value="paid" ${doc&&doc.status==='paid'?'selected':''}>مدفوعة</option>
            <option value="partial" ${doc&&doc.status==='partial'?'selected':''}>جزئي</option>
            <option value="cancelled" ${doc&&doc.status==='cancelled'?'selected':''}>ملغاة</option>
          </select>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><div class="card-title">💰 ملخص المستند</div></div>
        <div style="display:flex;flex-direction:column;gap:12px;padding:4px 0">
          <div class="flex-between" style="font-size:14px">
            <span style="color:var(--text-muted)">المجموع الفرعي</span>
            <span style="font-weight:700;direction:ltr" id="doc-subtotal">$0.00</span>
          </div>
          <div class="flex-between" style="font-size:14px">
            <span style="color:var(--text-muted)">الخصم %</span>
            <div class="flex gap-2" style="align-items:center">
              <input type="number" class="form-control" style="width:70px;text-align:center" id="doc-discount" value="${doc?doc.discount:0}" oninput="calcDocTotals()">
            </div>
          </div>
          <div class="flex-between" style="font-size:14px">
            <span style="color:var(--text-muted)">ضريبة VAT %</span>
            <div class="flex gap-2" style="align-items:center">
              <input type="number" class="form-control" style="width:70px;text-align:center" id="doc-tax" value="${doc?doc.tax:11}" oninput="calcDocTotals()">
            </div>
          </div>
          <div style="border-top:2px solid var(--primary);padding-top:12px" class="flex-between">
            <span style="font-size:16px;font-weight:700;color:var(--primary)">الإجمالي</span>
            <span style="font-size:24px;font-weight:900;color:var(--primary);direction:ltr" id="doc-total">$0.00</span>
          </div>
        </div>
        <div class="form-group mt-4">
          <label class="form-label">ملاحظات</label>
          <textarea class="form-control" id="doc-notes" rows="4">${doc?doc.notes:''}</textarea>
        </div>
      </div>
    </div>

    <div class="card mt-4">
      <div class="card-header">
        <div class="card-title">📦 أصناف المستند</div>
        <button class="btn btn-sm btn-primary no-print" onclick="addDocItemRow()">➕ إضافة صنف</button>
      </div>
      <div class="table-wrapper">
        <table id="doc-items-table">
          <thead>
            <tr>
              <th style="width:5%">#</th>
              <th style="width:15%">Item Number</th>
              <th style="width:30%">Description</th>
              <th style="width:10%">Qty</th>
              <th style="width:12%">U.Price</th>
              <th style="width:6%">D%</th>
              <th style="width:6%">V%</th>
              <th style="width:12%">Total</th>
              <th style="width:4%" class="no-print"></th>
            </tr>
          </thead>
          <tbody id="doc-items-body">
            ${itemRowsHtml}
          </tbody>
        </table>
      </div>
    </div>
    <!-- PRINT ONLY TOTALS -->
    <table class="print-totals-table" style="width:100%;margin-top:16px;border-collapse:collapse">
      <tr>
        <td style="width:60%;vertical-align:top;font-size:12px;padding:4px">
          <table style="width:100%;border-collapse:collapse;border:1px solid #999">
            <tr style="background:#e8e8e8"><td colspan="4" style="padding:4px 8px;font-weight:700;text-align:center;border:1px solid #999">Amount in Words</td></tr>
            <tr><td colspan="4" style="padding:6px 8px;font-size:11px;border:1px solid #999" id="print-amount-words">-</td></tr>
          </table>
          <table style="width:100%;border-collapse:collapse;border:1px solid #999;margin-top:8px">
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">Old Balance</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right;direction:ltr" id="print-old-balance">0.00</td></tr>
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">New Balance</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right;direction:ltr;font-weight:700" id="print-new-balance">0.00</td></tr>
          </table>
        </td>
        <td style="width:40%;vertical-align:top;padding-right:0">
          <table style="width:100%;border-collapse:collapse;border:1px solid #999">
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">Total Qty</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right" id="print-total-qty">0</td></tr>
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">Total Invoice</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right;direction:ltr" id="print-subtotal-val">0.00</td></tr>
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">Discount %</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right" id="print-discount-val">0</td></tr>
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">Gross Total</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right;direction:ltr" id="print-gross-val">0.00</td></tr>
            <tr><td style="padding:4px 8px;border:1px solid #999;font-size:11px">VAT %</td><td style="padding:4px 8px;border:1px solid #999;font-size:11px;text-align:right" id="print-tax-val">0</td></tr>
            <tr style="background:#e8e8e8"><td style="padding:6px 8px;border:1px solid #999;font-size:12px;font-weight:700">Net Total Invoice</td><td style="padding:6px 8px;border:1px solid #999;font-size:13px;font-weight:900;text-align:right;direction:ltr" id="print-net-total">0.00</td></tr>
          </table>
          <div style="margin-top:12px;font-size:11px"><strong>Signature:</strong></div>
        </td>
      </tr>
    </table>
  `;

  if (docItems.length === 0) addDocItemRow();
  calcDocTotals();
  loadPartyCache(); // load clients/suppliers for typeahead
}

// Store all items globally for typeahead
let _allItemsCache = [];

function buildItemRowHtml(idx, allItems, di) {
  _allItemsCache = allItems;
  const id = 'r' + (di ? (di._rowId || idx) : Date.now() + idx);
  if (di && !di._rowId) di._rowId = id;
  const selectedItem = di ? allItems.find(it => it.id == di.itemId) : null;
  const selectedName = selectedItem ? (selectedItem.code ? selectedItem.code + ' — ' + selectedItem.name : selectedItem.name) : '';
  return `
    <tr id="tr-${id}">
      <td style="width:5%;text-align:center;color:var(--text-muted);font-size:12px" class="row-num">${idx+1}</td>
      <td style="width:15%">
        <div class="typeahead-wrap">
          <input class="form-control typeahead-input" id="code-${id}" placeholder="كود / رقم الصنف"
            value="${selectedItem?selectedItem.code||'':''}"
            oninput="typeaheadSearch('${id}','code')"
            onkeydown="typeaheadKey(event,'${id}')"
            autocomplete="off">
          <div class="typeahead-dropdown" id="dd-${id}"></div>
        </div>
      </td>
      <td style="width:30%">
        <input class="form-control typeahead-input" id="name-${id}" placeholder="اسم الصنف"
          value="${selectedItem?selectedItem.name||'':''}"
          oninput="typeaheadSearch('${id}','name')"
          onkeydown="typeaheadKey(event,'${id}')"
          autocomplete="off">
      </td>
      <td style="width:10%"><input type="number" class="form-control" id="qty-${id}" value="${di?di.qty:1}" min="1" step="1" oninput="updateDocRow('${id}')"></td>
      <td style="width:12%"><input type="number" class="form-control" id="price-${id}" value="${di?di.price:0}" step="0.01" oninput="updateDocRow('${id}')"></td>
      <td style="width:6%;text-align:center"><input type="number" class="form-control" id="disc-${id}" value="${di?di.discount:0}" min="0" max="100" oninput="updateDocRow('${id}')" style="width:50px"></td>
      <td style="width:6%;text-align:center;color:var(--text-muted);font-size:11px">0</td>
      <td style="width:12%;font-weight:700;color:var(--primary);direction:ltr;text-align:right" id="tot-${id}">${di?fmt(di.total):'0.00'}</td>
      <td style="width:4%" class="no-print"><button class="btn btn-sm btn-danger" onclick="removeDocRow('${id}')">✕</button></td>
      <input type="hidden" id="sel-${id}" value="${di?di.itemId||'':''}">
    </tr>
  `;
}

function typeaheadSearch(id, field) {
  const codeEl = document.getElementById('code-'+id);
  const nameEl = document.getElementById('name-'+id);
  const dd = document.getElementById('dd-'+id);
  if (!dd) return;

  const query = (field === 'code' ? codeEl?.value : nameEl?.value || '').toLowerCase().trim();

  // Close all other dropdowns
  document.querySelectorAll('.typeahead-dropdown.open').forEach(d => { if(d.id !== 'dd-'+id) d.classList.remove('open'); });

  if (!query) { dd.classList.remove('open'); return; }

  const matches = _allItemsCache.filter(it =>
    (it.code||'').toLowerCase().includes(query) ||
    (it.name||'').toLowerCase().includes(query)
  ).slice(0, 10);

  if (!matches.length) { dd.innerHTML = '<div class="typeahead-item" style="color:var(--text-muted)">لا توجد نتائج</div>'; dd.classList.add('open'); return; }

  dd.innerHTML = matches.map((it,i) => `
    <div class="typeahead-item" data-idx="${i}" onclick="typeaheadSelect('${id}', ${it.id})">
      <span>${it.name}</span>
      <span class="item-code">${it.code||''}</span>
      <span class="item-price">$${fmt(it.price)}</span>
    </div>`).join('');
  dd.classList.add('open');
  dd._matches = matches;
}

function typeaheadSelect(id, itemId) {
  const item = _allItemsCache.find(it => it.id == itemId);
  if (!item) return;
  document.getElementById('code-'+id).value = item.code || '';
  document.getElementById('name-'+id).value = item.name || '';
  document.getElementById('sel-'+id).value = item.id;
  document.getElementById('price-'+id).value = item.price || 0;
  document.getElementById('dd-'+id).classList.remove('open');
  updateDocRow(id);
}

function typeaheadKey(e, id) {
  const dd = document.getElementById('dd-'+id);
  if (!dd || !dd.classList.contains('open')) return;
  const items = dd.querySelectorAll('.typeahead-item');
  let active = dd.querySelector('.typeahead-item.active');
  let idx = active ? parseInt(active.dataset.idx||0) : -1;
  if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx+1, items.length-1); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx-1, 0); }
  else if (e.key === 'Enter' && active) { e.preventDefault(); active.click(); return; }
  else if (e.key === 'Escape') { dd.classList.remove('open'); return; }
  items.forEach(el => el.classList.remove('active'));
  if (items[idx]) { items[idx].classList.add('active'); items[idx].scrollIntoView({block:'nearest'}); }
}

// Close dropdowns when clicking outside
document.addEventListener('click', e => {
  if (!e.target.closest('.typeahead-wrap')) {
    document.querySelectorAll('.typeahead-dropdown.open').forEach(d => d.classList.remove('open'));
  }
});

// ===== PARTY (CLIENT/SUPPLIER) TYPEAHEAD =====
let _partyCache = [];

async function loadPartyCache() {
  // Load accounts from Supabase
  const { data } = await supabaseClient.from('accounts').select('id, name, code').eq('company_id', currentCompany?.id);
  _partyCache = data || [];
}

function partyTypeaheadSearch() {
  const input = document.getElementById('doc-party');
  const dd = document.getElementById('party-dd');
  if (!input || !dd) return;
  const q = input.value.toLowerCase().trim();
  if (!q) { dd.classList.remove('open'); return; }

  const matches = _partyCache.filter(a =>
    (a.name||'').toLowerCase().includes(q) || (a.code||'').toLowerCase().includes(q)
  ).slice(0, 10);

  if (!matches.length) { dd.innerHTML = '<div class="typeahead-item" style="color:var(--text-muted)">لا توجد نتائج</div>'; dd.classList.add('open'); return; }

  dd.innerHTML = matches.map((a,i) => `
    <div class="typeahead-item" data-idx="${i}" onclick="partyTypeaheadSelect('${a.name}')">
      <span>${a.name}</span>
      <span class="item-code">${a.code||''}</span>
    </div>`).join('');
  dd.classList.add('open');
  dd._matches = matches;
}

function partyTypeaheadSelect(name) {
  const input = document.getElementById('doc-party');
  const dd = document.getElementById('party-dd');
  if (input) input.value = name;
  if (dd) dd.classList.remove('open');
  calcDocTotals();
}

function partyTypeaheadKey(e) {
  const dd = document.getElementById('party-dd');
  if (!dd || !dd.classList.contains('open')) return;
  const items = dd.querySelectorAll('.typeahead-item');
  let active = dd.querySelector('.typeahead-item.active');
  let idx = active ? parseInt(active.dataset.idx||0) : -1;
  if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx+1, items.length-1); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx-1, 0); }
  else if (e.key === 'Enter' && active) { e.preventDefault(); active.click(); return; }
  else if (e.key === 'Escape') { dd.classList.remove('open'); return; }
  items.forEach(el => el.classList.remove('active'));
  if (items[idx]) { items[idx].classList.add('active'); items[idx].scrollIntoView({block:'nearest'}); }
}

async function addDocItemRow() {
  const allItems = await dbGetAll('items');
  _allItemsCache = allItems;
  const id = 'r' + Date.now();
  const idx = docItems.length;
  const row = { _rowId:id, itemId:null, qty:1, price:0, discount:0, total:0 };
  docItems.push(row);
  const tbody = document.getElementById('doc-items-body');
  if (tbody) {
    const tr = document.createElement('tr');
    tr.id = 'tr-' + id;
    tr.innerHTML = `
      <td style="width:5%;text-align:center;color:var(--text-muted);font-size:12px" class="row-num">${idx+1}</td>
      <td style="width:15%">
        <div class="typeahead-wrap">
          <input class="form-control typeahead-input" id="code-${id}" placeholder="كود / رقم الصنف"
            oninput="typeaheadSearch('${id}','code')" onkeydown="typeaheadKey(event,'${id}')" autocomplete="off">
          <div class="typeahead-dropdown" id="dd-${id}"></div>
        </div>
      </td>
      <td style="width:30%">
        <input class="form-control typeahead-input" id="name-${id}" placeholder="اسم الصنف"
          oninput="typeaheadSearch('${id}','name')" onkeydown="typeaheadKey(event,'${id}')" autocomplete="off">
      </td>
      <td style="width:10%"><input type="number" class="form-control" id="qty-${id}" value="1" min="1" oninput="updateDocRow('${id}')"></td>
      <td style="width:12%"><input type="number" class="form-control" id="price-${id}" value="0" step="0.01" oninput="updateDocRow('${id}')"></td>
      <td style="width:6%;text-align:center"><input type="number" class="form-control" id="disc-${id}" value="0" oninput="updateDocRow('${id}')" style="width:50px"></td>
      <td style="width:6%;text-align:center;color:var(--text-muted);font-size:11px">0</td>
      <td style="width:12%;font-weight:700;color:var(--primary);direction:ltr;text-align:right" id="tot-${id}">0.00</td>
      <td style="width:4%" class="no-print"><button class="btn btn-sm btn-danger" onclick="removeDocRow('${id}')">✕</button></td>
      <input type="hidden" id="sel-${id}" value="">
    `;
    tbody.appendChild(tr);
    document.getElementById('code-'+id)?.focus();
  }
}

function updateDocRow(id) {
  const selEl = document.getElementById('sel-'+id);
  const nameEl = document.getElementById('name-'+id);
  const qty = parseFloat(document.getElementById('qty-'+id)?.value)||0;
  const disc = parseFloat(document.getElementById('disc-'+id)?.value)||0;
  let price = parseFloat(document.getElementById('price-'+id)?.value)||0;

  const total = qty * price * (1 - disc/100);
  const totEl = document.getElementById('tot-'+id);
  if (totEl) totEl.textContent = fmt(total);

  let row = docItems.find(r => r._rowId === id);
  if (!row) { row = { _rowId:id }; docItems.push(row); }
  row.itemId = selEl ? selEl.value : null;
  row.itemName = nameEl ? nameEl.value : '';
  row.qty = qty; row.price = price; row.discount = disc; row.total = total;
  calcDocTotals();
}

function removeDocRow(id) {
  document.getElementById('tr-'+id)?.remove();
  docItems = docItems.filter(r => r._rowId !== id);
  calcDocTotals();
}

function calcDocTotals() {
  const subtotal = docItems.reduce((s,r) => s+(r.total||0), 0);
  const discount = parseFloat(document.getElementById('doc-discount')?.value)||0;
  const tax = parseFloat(document.getElementById('doc-tax')?.value)||0;
  const afterDisc = subtotal * (1-discount/100);
  const total = afterDisc * (1+tax/100);

  const subEl = document.getElementById('doc-subtotal');
  const totEl = document.getElementById('doc-total');
  if (subEl) subEl.textContent = '$' + fmt(subtotal);
  if (totEl) totEl.textContent = '$' + fmt(total);

  // Update print totals
  const totalQty = docItems.reduce((s,r) => s+(r.qty||0), 0);
  const el = id => document.getElementById(id);
  if (el('print-total-qty')) el('print-total-qty').textContent = fmt(totalQty, 0);
  if (el('print-subtotal-val')) el('print-subtotal-val').textContent = fmt(subtotal);
  if (el('print-discount-val')) el('print-discount-val').textContent = fmt(discount, 2) + '%';
  if (el('print-gross-val')) el('print-gross-val').textContent = fmt(afterDisc);
  if (el('print-tax-val')) el('print-tax-val').textContent = fmt(tax, 2) + '%';
  if (el('print-net-total')) el('print-net-total').textContent = fmt(total);
  if (el('print-amount-words')) el('print-amount-words').textContent = numberToArabicWords(total) + ' دولار أمريكي لاغير';

  // Update print header fields
  const party = document.getElementById('doc-party')?.value || '';
  const date = document.getElementById('doc-date')?.value || '';
  const docNum = document.getElementById('doc-number')?.textContent || '';
  if (el('print-customer')) el('print-customer').textContent = party;
  if (el('print-date')) el('print-date').textContent = date;
  if (el('print-ref')) el('print-ref').textContent = docNum;
}

function numberToArabicWords(number) {
  const n = Math.floor(parseFloat(number) || 0);
  const ones = ['','واحد','اثنان','ثلاثة','أربعة','خمسة','ستة','سبعة','ثمانية','تسعة','عشرة','أحد عشر','اثنا عشر','ثلاثة عشر','أربعة عشر','خمسة عشر','ستة عشر','سبعة عشر','ثمانية عشر','تسعة عشر'];
  const tens = ['','','عشرون','ثلاثون','أربعون','خمسون','ستون','سبعون','ثمانون','تسعون'];
  if (n === 0) return 'صفر';
  if (n < 20) return ones[n];
  if (n < 100) return tens[Math.floor(n/10)] + (n%10 ? ' و' + ones[n%10] : '');
  if (n < 1000) return ones[Math.floor(n/100)] + ' مئة' + (n%100 ? ' و' + numberToArabicWords(n%100) : '');
  if (n < 1000000) return numberToArabicWords(Math.floor(n/1000)) + ' ألف' + (n%1000 ? ' و' + numberToArabicWords(n%1000) : '');
  return numberToArabicWords(Math.floor(n/1000000)) + ' مليون' + (n%1000000 ? ' و' + numberToArabicWords(n%1000000) : '');
}

async function saveDoc() {
  const cfg = DOC_TYPES[currentDocType];
  const party = document.getElementById('doc-party')?.value;
  if (!party) { notify('الرجاء اختيار ' + (currentLang==='AR'?cfg.partyLabel_ar:cfg.partyLabel_en), 'error'); return; }

  const subtotal = docItems.reduce((s,r) => s+(r.total||0),0);
  const discount = parseFloat(document.getElementById('doc-discount')?.value)||0;
  const tax = parseFloat(document.getElementById('doc-tax')?.value)||0;
  const total = +(subtotal*(1-discount/100)*(1+tax/100)).toFixed(2);

  const data = {
    number: document.getElementById('doc-number')?.textContent || '',
    party,
    date: document.getElementById('doc-date')?.value || '',
    dueDate: document.getElementById('doc-due')?.value || '',
    warehouse: document.getElementById('doc-warehouse')?.value || '',
    status: document.getElementById('doc-status')?.value || 'unpaid',
    subtotal, discount, tax, total,
    notes: document.getElementById('doc-notes')?.value || '',
    items: docItems.map(r => ({...r})),
    docType: currentDocType,
  };

  if (currentDocId !== null) data.id = currentDocId;

  const savedId = await dbPut(cfg.store, data);
  notify('تم حفظ المستند بنجاح ✓');

  // After save, reload for edit so user can continue editing
  const realId = currentDocId || savedId;
  setTimeout(()=>{ openDocPage(currentDocType, realId); }, 300);
}

// ============ INVOICE LIST ============
async function renderInvoicesList() {
  const invoices = await dbGetAll('invoices');
  const search = (document.getElementById('inv-search')?.value||'').toLowerCase();
  const filtered = invoices.filter(i => !search || (i.number||'').toLowerCase().includes(search) || (i.party||'').toLowerCase().includes(search));

  const statusLabel = s => ({ paid:'مدفوعة', unpaid:'غير مدفوعة', partial:'جزئي', cancelled:'ملغاة' }[s] || s);
  const statusBadge = s => ({ paid:'badge-success', unpaid:'badge-warning', partial:'badge-info', cancelled:'badge-danger' }[s] || 'badge-secondary');

  document.getElementById('invoices-list-body').innerHTML = filtered.reverse().map(inv => `
    <tr>
      <td><code>${inv.number}</code></td>
      <td style="font-weight:600">${inv.party||'-'}</td>
      <td>${inv.date||'-'}</td>
      <td>${inv.dueDate||'-'}</td>
      <td style="font-weight:700;color:var(--primary);direction:ltr">$${fmt(inv.total)}</td>
      <td><span class="badge ${statusBadge(inv.status)}">${statusLabel(inv.status)}</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-outline" onclick="editDoc('invoices',${inv.id})">✏️ تعديل</button>
        <button class="btn btn-sm btn-outline" onclick="printDoc('invoices',${inv.id})" style="margin-right:4px">🖨 طباعة</button>
        <button class="btn btn-sm btn-danger" onclick="deleteDoc('invoices',${inv.id})" style="margin-right:4px">🗑</button>
      </td>
    </tr>
  `).join('') || '<tr><td colspan="7"><div class="empty-state"><div class="icon">🧾</div><p>لا توجد فواتير</p></div></td></tr>';
}

