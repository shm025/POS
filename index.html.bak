  notify('تم حفظ إعدادات الشركة');
  const n=document.getElementById('co-name-ar')?.value||'CATALAN POS';
  document.getElementById('topbar-company-name').textContent=n;
  document.getElementById('trial-co-name').textContent=n;
}

