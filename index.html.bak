function setLang(lang) {
  currentLang=lang;
  localStorage.setItem('catalan_lang',lang);
  document.querySelectorAll('.lang-btn').forEach(b=>{
    b.classList.remove('active');
    if(b.dataset.lang===lang) b.classList.add('active');
  });
  const html=document.documentElement;
  if(lang==='EN'||lang==='FR'){html.setAttribute('dir','ltr');html.setAttribute('lang',lang.toLowerCase());}
  else{html.setAttribute('dir','rtl');html.setAttribute('lang','ar');}
  const t=i18n[lang]||i18n.AR;
  document.querySelectorAll('[data-i18n]').forEach(el=>{
  const k=el.getAttribute('data-i18n');
  if(t[k]) el.textContent=t[k];
});
// Restore company info after language change
if (currentCompany) {
  const nameEl = document.getElementById('topbar-company-name');
  if (nameEl) nameEl.textContent = currentCompany.name;
  const subtitleEl = document.getElementById('topbar-subtitle');
  if (subtitleEl) subtitleEl.textContent = currentCompany.address || '';
  const usernameEl = document.getElementById('topbar-username');
  // Don't overwrite username from i18n
}
// Fix direction for nav-item active border
document.querySelectorAll('.nav-item.active').forEach(n => {
  if (lang==='EN'||lang==='FR') { n.style.borderRight='none'; n.style.borderLeft='3px solid var(--accent)'; }
  else { n.style.borderLeft='none'; n.style.borderRight='3px solid var(--accent)'; }
});
  // Only re-render if user is logged in
  if (!currentCompany) return;
  const ap=document.querySelector('.page-view.active')?.id?.replace('page-','');
  if(ap){
    if(['invoices','sales-return','orders','purchases','purchases-return'].includes(ap)) openDocPage(ap, currentDocId);
    else showPage(ap);
  }
  // Restore company info after language change
  if (currentCompany) {
    const nameEl = document.getElementById('topbar-company-name');
    if (nameEl) nameEl.textContent = currentCompany.name;
    const subtitleEl = document.getElementById('topbar-subtitle');
    if (subtitleEl) subtitleEl.textContent = currentCompany.address || '';
  }
}

// ============ AI ============
function toggleAI(){document.getElementById('ai-window').classList.toggle('open');}
async function sendAIMessage(){
  const input=document.getElementById('ai-input');const msg=input.value.trim();if(!msg)return;
  appendAIMsg(msg,'user');input.value='';
  const typEl=document.createElement('div');typEl.className='ai-msg bot';typEl.id='ai-typing';
  typEl.innerHTML='<span class="loading-spinner" style="border-color:rgba(0,0,0,0.2);border-top-color:var(--primary)"></span> جاري البحث...';
  document.getElementById('ai-messages').appendChild(typEl);
  document.getElementById('ai-messages').scrollTop=99999;
  try{
    const items=await dbGetAll('items');
    const inventory=items.map(i=>`${i.name} (${i.code}): stock=${i.stock}, price=$${i.price}`).join('\n');
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:`You are a smart assistant for CATALAN POS system. Current inventory:\n${inventory}\n\nAlways reply in the same language the user writes in. Be concise and helpful.`,messages:[{role:'user',content:msg}]})});
    const data=await res.json();
    const reply=data.content?.map(c=>c.text||'').filter(Boolean).join('\n')||'عذراً، لم أتمكن من الإجابة.';
    document.getElementById('ai-typing')?.remove();appendAIMsg(reply,'bot');
  }catch(e){document.getElementById('ai-typing')?.remove();appendAIMsg('عذراً، حدث خطأ في الاتصال.','bot');}
}
function appendAIMsg(text,role){
  const msgs=document.getElementById('ai-messages');
  const div=document.createElement('div');div.className=`ai-msg ${role}`;div.textContent=text;
  msgs.appendChild(div);msgs.scrollTop=msgs.scrollHeight;
}
// ============ ROYAL CUTS — SERVICES ============
async function renderServices() {
  if (!currentCompany) return;
  const { data: services } = await supabaseClient
    .from('services')
    .select('*')
    .eq('company_id', currentCompany.id)
    .order('created_at', { ascending: true });

  const svcs = services || [];
  document.getElementById('services-table-body').innerHTML = svcs.length ? svcs.map(s => `
    <tr>
      <td style="font-weight:600">${s.name}</td>
      <td style="direction:ltr">$${fmt(s.base_price)}</td>
      <td style="direction:ltr">$${fmt(s.junior_price)}</td>
      <td style="direction:ltr">$${fmt(s.senior_price)}</td>
      <td style="direction:ltr">$${fmt(s.master_price)}</td>
      <td>${fmtInt(s.duration_minutes)} د</td>
      <td><span class="badge ${s.active ? 'badge-success' : 'badge-danger'}">${s.active ? 'نشطة' : 'موقوفة'}</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-outline" onclick="editService('${s.id}')">✏️</button>
        <button class="btn btn-sm btn-danger" onclick="deleteService('${s.id}')" style="margin-right:4px">🗑</button>
      </td>
    </tr>
  `).join('') : `
    <tr><td colspan="8">
      <div class="empty-state">
        <div class="icon">✂️</div>
        <p>لا توجد خدمات</p>
        <span>أضف خدماتك مثل: قصة شعر، تحديد لحية، غسيل شعر</span>
      </div>
    </td></tr>`;
}

async function saveService() {
  const name = document.getElementById('svc-name').value.trim();
  if (!name) { notify('أدخل اسم الخدمة', 'error'); return; }
  const editId = document.getElementById('edit-service-id').value;
  const data = {
    company_id: currentCompany.id,
    name,
    base_price: parseFloat(document.getElementById('svc-base-price').value) || 0,
    junior_price: parseFloat(document.getElementById('svc-junior-price').value) || 0,
    senior_price: parseFloat(document.getElementById('svc-senior-price').value) || 0,
    master_price: parseFloat(document.getElementById('svc-master-price').value) || 0,
    duration_minutes: parseInt(document.getElementById('svc-duration').value) || 30,
    active: true,
  };
  if (editId) {
    await supabaseClient.from('services').update(data).eq('id', editId);
  } else {
    await supabaseClient.from('services').insert(data);
  }
  closeModal('service-modal');
  notify('تم حفظ الخدمة بنجاح');
  clearServiceForm();
  renderServices();
}

async function editService(id) {
  const { data: s } = await supabaseClient.from('services').select('*').eq('id', id).single();
  if (!s) return;
  document.getElementById('edit-service-id').value = s.id;
  document.getElementById('svc-name').value = s.name;
  document.getElementById('svc-base-price').value = s.base_price;
  document.getElementById('svc-junior-price').value = s.junior_price;
  document.getElementById('svc-senior-price').value = s.senior_price;
  document.getElementById('svc-master-price').value = s.master_price;
  document.getElementById('svc-duration').value = s.duration_minutes;
  document.getElementById('service-modal-title').textContent = '✏️ تعديل الخدمة';
  openModal('service-modal');
}

async function deleteService(id) {
  if (!confirm('هل تريد حذف هذه الخدمة؟')) return;
  await supabaseClient.from('services').delete().eq('id', id);
  notify('تم حذف الخدمة');
  renderServices();
}

function clearServiceForm() {
  document.getElementById('edit-service-id').value = '';
  document.getElementById('svc-name').value = '';
  document.getElementById('svc-base-price').value = 0;
  document.getElementById('svc-junior-price').value = 0;
  document.getElementById('svc-senior-price').value = 0;
  document.getElementById('svc-master-price').value = 0;
  document.getElementById('svc-duration').value = 30;
  document.getElementById('service-modal-title').textContent = '✂️ خدمة جديدة';
}
// ============ ROYAL CUTS — EMPLOYEES ============
async function renderEmployees() {
  if (!currentCompany) return;
  const { data: employees } = await supabaseClient
    .from('employees')
    .select('*')
    .eq('company_id', currentCompany.id)
    .eq('active', true);

  const { data: reservations } = await supabaseClient
    .from('reservations')
    .select('*')
    .eq('company_id', currentCompany.id)
    .eq('status', 'done');

  const emps = employees || [];
  const res = reservations || [];

  // Stats
  const totalEmps = emps.length;
  const thisMonth = new Date().toISOString().slice(0, 7);
  const monthRes = res.filter(r => r.date && r.date.startsWith(thisMonth));
  const totalRevenue = monthRes.reduce((s, r) => s + parseFloat(r.price || 0), 0);

  document.getElementById('employee-stats').innerHTML = `
    <div class="stat-card"><div class="stat-label">عدد الموظفين</div><div class="stat-value">${fmtInt(totalEmps)}</div></div>
    <div class="stat-card"><div class="stat-label">قطعات هذا الشهر</div><div class="stat-value">${fmtInt(monthRes.length)}</div></div>
    <div class="stat-card"><div class="stat-label">إيرادات هذا الشهر</div><div class="stat-value" style="font-size:18px;direction:ltr">$${fmt(totalRevenue)}</div></div>
  `;

  const levelLabel = { junior: 'Junior', senior: 'Senior', master: 'Master' };
  const salaryLabel = { commission: 'عمولة فقط', salary_commission: 'راتب + عمولة', salary: 'راتب ثابت' };

  document.getElementById('employees-table-body').innerHTML = emps.length ? emps.map(emp => {
    const empRes = monthRes.filter(r => r.employee_id === emp.id);
    const empRevenue = empRes.reduce((s, r) => s + parseFloat(r.price || 0), 0);
    let due = 0;
    if (emp.salary_type === 'commission') due = empRevenue * (emp.commission_rate / 100);
    else if (emp.salary_type === 'salary_commission') due = parseFloat(emp.base_salary || 0) + empRevenue * (emp.commission_rate / 100);
    else due = parseFloat(emp.base_salary || 0);

    return `<tr>
      <td style="font-weight:600">${emp.name}</td>
      <td style="direction:ltr">${emp.phone || '-'}</td>
      <td><span class="badge badge-info">${levelLabel[emp.level] || emp.level}</span></td>
      <td>${salaryLabel[emp.salary_type] || emp.salary_type}</td>
      <td style="direction:ltr">$${fmt(emp.base_salary)}</td>
      <td>${fmtInt(emp.commission_rate)}%</td>
      <td style="font-weight:700">${fmtInt(empRes.length)}</td>
      <td style="font-weight:700;color:var(--success);direction:ltr">$${fmt(due)}</td>
      <td><span class="badge badge-success">نشط</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-outline" onclick="editEmployee('${emp.id}')">✏️</button>
        <button class="btn btn-sm btn-danger" onclick="deleteEmployee('${emp.id}')" style="margin-right:4px">🗑</button>
      </td>
    </tr>`;
  }).join('') : '<tr><td colspan="10"><div class="empty-state"><div class="icon">👥</div><p>لا يوجد موظفون</p><span>أضف موظفاً جديداً</span></div></td></tr>';
}

function toggleSalaryFields() {
  const type = document.getElementById('emp-salary-type').value;
  const baseSalaryGroup = document.getElementById('base-salary-group');
  const commissionGroup = document.getElementById('commission-group');
  baseSalaryGroup.style.display = type === 'commission' ? 'none' : 'block';
  commissionGroup.style.display = type === 'salary' ? 'none' : 'block';
}

async function saveEmployee() {
  const name = document.getElementById('emp-name').value.trim();
  if (!name) { notify('أدخل اسم الموظف', 'error'); return; }
  const editId = document.getElementById('edit-employee-id').value;
  const data = {
    company_id: currentCompany.id,
    name,
    phone: document.getElementById('emp-phone').value,
    level: document.getElementById('emp-level').value,
    salary_type: document.getElementById('emp-salary-type').value,
    base_salary: parseFloat(document.getElementById('emp-base-salary').value) || 0,
    commission_rate: parseFloat(document.getElementById('emp-commission').value) || 0,
    active: true,
  };
  if (editId) {
    await supabaseClient.from('employees').update(data).eq('id', editId);
  } else {
    await supabaseClient.from('employees').insert(data);
  }
  closeModal('employee-modal');
  notify('تم حفظ الموظف بنجاح');
  renderEmployees();
}

async function editEmployee(id) {
  const { data: emp } = await supabaseClient.from('employees').select('*').eq('id', id).single();
  if (!emp) return;
  document.getElementById('edit-employee-id').value = emp.id;
  document.getElementById('emp-name').value = emp.name;
  document.getElementById('emp-phone').value = emp.phone || '';
  document.getElementById('emp-level').value = emp.level;
  document.getElementById('emp-salary-type').value = emp.salary_type;
  document.getElementById('emp-base-salary').value = emp.base_salary;
  document.getElementById('emp-commission').value = emp.commission_rate;
  document.getElementById('employee-modal-title').textContent = '✏️ تعديل الموظف';
  toggleSalaryFields();
  openModal('employee-modal');
}

async function deleteEmployee(id) {
  if (!confirm('هل تريد حذف هذا الموظف؟')) return;
  await supabaseClient.from('employees').update({ active: false }).eq('id', id);
  notify('تم حذف الموظف');
  renderEmployees();
}

// ============ ROYAL CUTS — RESERVATIONS ============
async function renderReservations() {
  if (!currentCompany) return;
  const search = (document.getElementById('res-search')?.value || '').toLowerCase();
  const statusFilter = document.getElementById('res-status-filter')?.value || '';
  const dateFilter = document.getElementById('res-date-filter')?.value || '';

  let query = supabaseClient.from('reservations').select('*').eq('company_id', currentCompany.id).order('date', { ascending: false });
  if (statusFilter) query = query.eq('status', statusFilter);
  if (dateFilter) query = query.eq('date', dateFilter);

  const { data: reservations } = await query;
  const res = reservations || [];
  const filtered = search ? res.filter(r => r.customer_name?.toLowerCase().includes(search)) : res;

  const statusLabel = { pending: 'قيد الانتظار', confirmed: 'مؤكد', done: 'منجز', cancelled: 'ملغى' };
  const statusBadge = { pending: 'badge-warning', confirmed: 'badge-info', done: 'badge-success', cancelled: 'badge-danger' };

  document.getElementById('reservations-table-body').innerHTML = filtered.length ? filtered.map(r => `
    <tr>
      <td style="font-weight:600">${r.customer_name}</td>
      <td style="direction:ltr">${r.customer_phone || '-'}</td>
      <td>${r.service_name || '-'}</td>
      <td>${r.employee_name || '-'}</td>
      <td>${r.date || '-'}</td>
      <td style="direction:ltr">${r.time || '-'}</td>
      <td style="font-weight:700;direction:ltr">$${fmt(r.price)}</td>
      <td><span class="badge ${statusBadge[r.status] || 'badge-secondary'}">${statusLabel[r.status] || r.status}</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-outline" onclick="editReservation('${r.id}')">✏️</button>
        <button class="btn btn-sm btn-success btn-sm" onclick="markDone('${r.id}')" style="margin-right:4px">✅</button>
        <button class="btn btn-sm btn-danger" onclick="deleteReservation('${r.id}')" style="margin-right:4px">🗑</button>
      </td>
    </tr>
  `).join('') : '<tr><td colspan="9"><div class="empty-state"><div class="icon">📅</div><p>لا توجد حجوزات</p></div></td></tr>';
}

async function openReservationModal() {
  document.getElementById('edit-reservation-id').value = '';
  document.getElementById('reservation-modal-title').textContent = '📅 حجز جديد';

  const today = new Date().toISOString().split('T')[0];
  document.getElementById('res-date').value = today;
  document.getElementById('res-customer-name').value = '';
  document.getElementById('res-customer-phone').value = '';
  document.getElementById('res-notes').value = '';
  document.getElementById('res-price').value = 0;
  document.getElementById('res-status').value = 'pending';

  const { data: services } = await supabaseClient.from('services').select('*').eq('company_id', currentCompany.id).eq('active', true);
  const { data: employees } = await supabaseClient.from('employees').select('*').eq('company_id', currentCompany.id).eq('active', true);

  const servicesSel = document.getElementById('res-service');
  servicesSel.innerHTML = '<option value="">-- اختر خدمة --</option>' + (services || []).map(s => `<option value="${s.id}" data-base="${s.base_price}" data-junior="${s.junior_price}" data-senior="${s.senior_price}" data-master="${s.master_price}">${s.name} - $${fmt(s.base_price)}</option>`).join('');

  const empSel = document.getElementById('res-employee');
  empSel.innerHTML = '<option value="">-- اختر حلاق --</option>' + (employees || []).map(e => `<option value="${e.id}" data-level="${e.level}" data-name="${e.name}">${e.name} (${e.level})</option>`).join('');

  openModal('reservation-modal');
}

async function updateReservationPrice() {
  const serviceSel = document.getElementById('res-service');
  const empSel = document.getElementById('res-employee');
  if (!serviceSel.value || !empSel.value) return;
  const opt = serviceSel.options[serviceSel.selectedIndex];
  const empOpt = empSel.options[empSel.selectedIndex];
  const level = empOpt.dataset.level;
  let price = parseFloat(opt.dataset.base) || 0;
  if (level === 'junior' && opt.dataset.junior) price = parseFloat(opt.dataset.junior) || price;
  else if (level === 'senior' && opt.dataset.senior) price = parseFloat(opt.dataset.senior) || price;
  else if (level === 'master' && opt.dataset.master) price = parseFloat(opt.dataset.master) || price;
  document.getElementById('res-price').value = price;
}

async function saveReservation() {
  const customerName = document.getElementById('res-customer-name').value.trim();
  if (!customerName) { notify('أدخل اسم العميل', 'error'); return; }
  const editId = document.getElementById('edit-reservation-id').value;
  const serviceSel = document.getElementById('res-service');
  const empSel = document.getElementById('res-employee');
  const data = {
    company_id: currentCompany.id,
    customer_name: customerName,
    customer_phone: document.getElementById('res-customer-phone').value,
    service_id: serviceSel.value || null,
    service_name: serviceSel.value ? serviceSel.options[serviceSel.selectedIndex].text.split(' - ')[0] : null,
    employee_id: empSel.value || null,
    employee_name: empSel.value ? empSel.options[empSel.selectedIndex].dataset.name : null,
    price: parseFloat(document.getElementById('res-price').value) || 0,
    date: document.getElementById('res-date').value,
    time: document.getElementById('res-time').value,
    status: document.getElementById('res-status').value,
    notes: document.getElementById('res-notes').value,
  };
  if (editId) {
    await supabaseClient.from('reservations').update(data).eq('id', editId);
  } else {
    await supabaseClient.from('reservations').insert(data);
  }
  closeModal('reservation-modal');
  notify('تم حفظ الحجز بنجاح');
  renderReservations();
}

async function editReservation(id) {
  const { data: r } = await supabaseClient.from('reservations').select('*').eq('id', id).single();
  if (!r) return;
  await openReservationModal();
  document.getElementById('edit-reservation-id').value = r.id;
  document.getElementById('res-customer-name').value = r.customer_name;
  document.getElementById('res-customer-phone').value = r.customer_phone || '';
  document.getElementById('res-date').value = r.date || '';
  document.getElementById('res-time').value = r.time || '';
  document.getElementById('res-price').value = r.price || 0;
  document.getElementById('res-status').value = r.status;
  document.getElementById('res-notes').value = r.notes || '';
  document.getElementById('reservation-modal-title').textContent = '✏️ تعديل الحجز';
}

async function markDone(id) {
  await supabaseClient.from('reservations').update({ status: 'done' }).eq('id', id);
  notify('تم تأكيد إنجاز الحجز ✅');
  renderReservations();
}

async function deleteReservation(id) {
  if (!confirm('هل تريد حذف هذا الحجز؟')) return;
  await supabaseClient.from('reservations').delete().eq('id', id);
  notify('تم حذف الحجز');
  renderReservations();
}

// ============ ROYAL CUTS — SUPPLIES ============
async function renderSupplies() {
  if (!currentCompany) return;
  const { data: supplies } = await supabaseClient.from('supplies').select('*').eq('company_id', currentCompany.id).order('date', { ascending: false });
  const sup = supplies || [];
  const thisMonth = new Date().toISOString().slice(0, 7);
  const monthSup = sup.filter(s => s.date && s.date.startsWith(thisMonth));
  const totalMonth = monthSup.reduce((s, r) => s + parseFloat(r.amount || 0), 0);
  const totalAll = sup.reduce((s, r) => s + parseFloat(r.amount || 0), 0);

  document.getElementById('supplies-stats').innerHTML = `
    <div class="stat-card"><div class="stat-label">مصاريف هذا الشهر</div><div class="stat-value" style="direction:ltr">$${fmt(totalMonth)}</div></div>
    <div class="stat-card"><div class="stat-label">إجمالي المصاريف</div><div class="stat-value" style="direction:ltr">$${fmt(totalAll)}</div></div>
    <div class="stat-card"><div class="stat-label">عدد السجلات</div><div class="stat-value">${fmtInt(sup.length)}</div></div>
  `;

  const catLabel = { supply: 'مستلزم', tool: 'أداة', product: 'منتج', other: 'أخرى' };
  document.getElementById('supplies-table-body').innerHTML = sup.length ? sup.map(s => `
    <tr>
      <td style="font-weight:600">${s.name}</td>
      <td><span class="badge badge-info">${catLabel[s.category] || s.category}</span></td>
      <td style="font-weight:700;direction:ltr">$${fmt(s.amount)}</td>
      <td>${s.date || '-'}</td>
      <td>${s.notes || '-'}</td>
      <td class="no-print"><button class="btn btn-sm btn-danger" onclick="deleteSupply('${s.id}')">🗑</button></td>
    </tr>
  `).join('') : '<tr><td colspan="6"><div class="empty-state"><div class="icon">🧴</div><p>لا توجد مستلزمات</p></div></td></tr>';
}

async function saveSupply() {
  const name = document.getElementById('sup-name').value.trim();
  if (!name) { notify('أدخل اسم المستلزم', 'error'); return; }
  await supabaseClient.from('supplies').insert({
    company_id: currentCompany.id,
    name,
    category: document.getElementById('sup-category').value,
    amount: parseFloat(document.getElementById('sup-amount').value) || 0,
    date: document.getElementById('sup-date').value,
    notes: document.getElementById('sup-notes').value,
  });
  closeModal('supply-modal');
  notify('تم حفظ المستلزم');
  renderSupplies();
}

async function deleteSupply(id) {
  if (!confirm('حذف هذا السجل؟')) return;
  await supabaseClient.from('supplies').delete().eq('id', id);
  notify('تم الحذف');
  renderSupplies();
}

// ============ ROYAL CUTS — BILLS ============
async function renderBills() {
  if (!currentCompany) return;
  const { data: bills } = await supabaseClient.from('bills').select('*').eq('company_id', currentCompany.id).order('created_at', { ascending: false });
  const bl = bills || [];
  const unpaid = bl.filter(b => !b.paid);
  const totalUnpaid = unpaid.reduce((s, b) => s + parseFloat(b.amount || 0), 0);
  const totalPaid = bl.filter(b => b.paid).reduce((s, b) => s + parseFloat(b.amount || 0), 0);

  document.getElementById('bills-stats').innerHTML = `
    <div class="stat-card"><div class="stat-label">غير مدفوعة</div><div class="stat-value" style="color:var(--danger);direction:ltr">$${fmt(totalUnpaid)}</div></div>
    <div class="stat-card"><div class="stat-label">مدفوعة</div><div class="stat-value" style="color:var(--success);direction:ltr">$${fmt(totalPaid)}</div></div>
    <div class="stat-card"><div class="stat-label">إجمالي الفواتير</div><div class="stat-value">${fmtInt(bl.length)}</div></div>
  `;

  document.getElementById('bills-table-body').innerHTML = bl.length ? bl.map(b => `
    <tr>
      <td style="font-weight:600">${b.name}</td>
      <td style="font-weight:700;direction:ltr">$${fmt(b.amount)}</td>
      <td>${b.due_day || '-'}</td>
      <td>${b.month || '-'}</td>
      <td><span class="badge ${b.paid ? 'badge-success' : 'badge-danger'}">${b.paid ? 'مدفوعة' : 'غير مدفوعة'}</span></td>
      <td class="no-print">
        <button class="btn btn-sm btn-success" onclick="toggleBillPaid('${b.id}', ${b.paid})">${b.paid ? 'إلغاء الدفع' : '✅ دفع'}</button>
        <button class="btn btn-sm btn-danger" onclick="deleteBill('${b.id}')" style="margin-right:4px">🗑</button>
      </td>
    </tr>
  `).join('') : '<tr><td colspan="6"><div class="empty-state"><div class="icon">💡</div><p>لا توجد فواتير</p></div></td></tr>';
}

async function saveBill() {
  const name = document.getElementById('bill-name').value.trim();
  if (!name) { notify('أدخل اسم الفاتورة', 'error'); return; }
  await supabaseClient.from('bills').insert({
    company_id: currentCompany.id,
    name,
    amount: parseFloat(document.getElementById('bill-amount').value) || 0,
    due_day: parseInt(document.getElementById('bill-due-day').value) || 1,
    month: document.getElementById('bill-month').value,
    paid: false,
  });
  closeModal('bill-modal');
  notify('تم حفظ الفاتورة');
  renderBills();
}

async function toggleBillPaid(id, currentPaid) {
  await supabaseClient.from('bills').update({ paid: !currentPaid }).eq('id', id);
  notify(!currentPaid ? 'تم تأكيد الدفع ✅' : 'تم إلغاء الدفع');
  renderBills();
}

async function deleteBill(id) {
  if (!confirm('حذف هذه الفاتورة؟')) return;
  await supabaseClient.from('bills').delete().eq('id', id);
  notify('تم الحذف');
  renderBills();
}

// ============ INIT ============
async function init() {
  await initDB();
  await seedData();
  setLang(currentLang);
  await checkSession();
}
init();
</script>
</body>
</html>
